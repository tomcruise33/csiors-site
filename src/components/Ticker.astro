---
import { getCollection } from 'astro:content';

// Build-time: pull latest 6 real CSIORS articles
const allExpert = (await getCollection('expert'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);

const csiors = allExpert.map(a => {
  const region = a.data.region || 'MENA';
  const title = a.data.title.length > 65
    ? a.data.title.slice(0, 62) + '...'
    : a.data.title;
  return { source: 'CSIORS', region, title };
});

const csioursJson = JSON.stringify(csiors);
---
<div class="ticker" id="ticker">
  <div class="ticker-track" id="ticker-track">
    {csiors.map(item => (
      <span class="ticker-item">
        <span class="ticker-pip"></span>
        <span class="ticker-source">{item.source}</span> {item.region}: {item.title}
      </span>
    ))}
    {csiors.map(item => (
      <span class="ticker-item">
        <span class="ticker-pip"></span>
        <span class="ticker-source">{item.source}</span> {item.region}: {item.title}
      </span>
    ))}
  </div>
</div>

<script define:vars={{ csioursJson }}>
  function buildTickerHTML(items) {
    return items.map(item => {
      const srcClass = item.source === 'CSIORS' ? 'ticker-source' : 'ticker-source ticker-source-rw';
      return '<span class="ticker-item"><span class="ticker-pip"></span><span class="' + srcClass + '">' + item.source + '</span> ' + item.region + ': ' + item.title + '</span>';
    }).join('');
  }

  async function enhanceTicker() {
    const track = document.getElementById('ticker-track');
    if (!track) return;

    try {
      const res = await fetch('/data/ticker');
      if (!res.ok) return;
      const rwItems = await res.json();
      if (!rwItems.length) return;

      // Interleave: CSIORS, RW, CSIORS, RW, ...
      const csiors = JSON.parse(csioursJson);
      const merged = [];
      const max = Math.max(csiors.length, rwItems.length);
      for (let i = 0; i < max; i++) {
        if (i < csiors.length) merged.push(csiors[i]);
        if (i < rwItems.length) merged.push(rwItems[i]);
      }

      const html = buildTickerHTML(merged);
      track.innerHTML = html + html;
    } catch {
      // Silently degrade to CSIORS-only
    }
  }

  enhanceTicker();
</script>
