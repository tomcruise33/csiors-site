---
import { getCollection } from 'astro:content';

// Pull latest 8 real articles for the ticker
const allExpert = (await getCollection('expert'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 8);

const items = allExpert.map(a => {
  const region = a.data.region || 'MENA';
  // Truncate long titles for the ticker
  const title = a.data.title.length > 70
    ? a.data.title.slice(0, 67) + '...'
    : a.data.title;
  return { region, title };
});
---
{items.length > 0 && (
<div class="ticker">
  <div class="ticker-track">
    {items.map(item => (
      <span class="ticker-item">
        <span class="ticker-pip"></span> {item.region}: {item.title}
      </span>
    ))}
    {items.map(item => (
      <span class="ticker-item">
        <span class="ticker-pip"></span> {item.region}: {item.title}
      </span>
    ))}
  </div>
</div>
)}
