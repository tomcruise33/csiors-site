---
interface Props {
  size?: number;
  class?: string;
}
const { size = 42, class: className = '' } = Astro.props;
---
<svg class={className} width={size} height={size} viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="logoGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0693E3"/>
      <stop offset="100%" style="stop-color:#9B51E0"/>
    </linearGradient>
    <radialGradient id="logoBg" cx="50%" cy="50%" r="50%">
      <stop offset="0%" style="stop-color:#0f2a3a"/>
      <stop offset="100%" style="stop-color:#0a0c14"/>
    </radialGradient>
  </defs>
  <circle cx="60" cy="60" r="56" fill="url(#logoBg)" stroke="url(#logoGrad)" stroke-width="1" opacity="0.8"/>
  <rect x="10" y="10" width="100" height="100" rx="12" fill="none" stroke="url(#logoGrad)" stroke-width="1.2" opacity="0.5"/>
  <g opacity="0.7" fill="none" stroke="url(#logoGrad)" stroke-width="0.9">
    <ellipse cx="60" cy="28" rx="12" ry="18" transform="rotate(0 60 60)"/>
    <ellipse cx="60" cy="28" rx="12" ry="18" transform="rotate(45 60 60)"/>
    <ellipse cx="60" cy="28" rx="12" ry="18" transform="rotate(90 60 60)"/>
    <ellipse cx="60" cy="28" rx="12" ry="18" transform="rotate(135 60 60)"/>
    <ellipse cx="60" cy="28" rx="12" ry="18" transform="rotate(180 60 60)"/>
    <ellipse cx="60" cy="28" rx="12" ry="18" transform="rotate(225 60 60)"/>
    <ellipse cx="60" cy="28" rx="12" ry="18" transform="rotate(270 60 60)"/>
    <ellipse cx="60" cy="28" rx="12" ry="18" transform="rotate(315 60 60)"/>
  </g>
  <g opacity="0.5" fill="none" stroke="url(#logoGrad)" stroke-width="0.7">
    <ellipse cx="60" cy="38" rx="8" ry="12" transform="rotate(22.5 60 60)"/>
    <ellipse cx="60" cy="38" rx="8" ry="12" transform="rotate(67.5 60 60)"/>
    <ellipse cx="60" cy="38" rx="8" ry="12" transform="rotate(112.5 60 60)"/>
    <ellipse cx="60" cy="38" rx="8" ry="12" transform="rotate(157.5 60 60)"/>
    <ellipse cx="60" cy="38" rx="8" ry="12" transform="rotate(202.5 60 60)"/>
    <ellipse cx="60" cy="38" rx="8" ry="12" transform="rotate(247.5 60 60)"/>
    <ellipse cx="60" cy="38" rx="8" ry="12" transform="rotate(292.5 60 60)"/>
    <ellipse cx="60" cy="38" rx="8" ry="12" transform="rotate(337.5 60 60)"/>
  </g>
  <circle cx="60" cy="60" r="14" fill="#0a0c14" stroke="url(#logoGrad)" stroke-width="0.8" opacity="0.6"/>
  <circle cx="60" cy="16" r="1.5" fill="#0693E3" opacity="0.8"/>
  <circle cx="92" cy="36" r="1.2" fill="#9B51E0" opacity="0.6"/>
  <circle cx="98" cy="60" r="1" fill="#0693E3" opacity="0.5"/>
  <circle cx="28" cy="36" r="1.2" fill="#0693E3" opacity="0.6"/>
  <circle cx="22" cy="60" r="1" fill="#9B51E0" opacity="0.5"/>
  <circle cx="36" cy="90" r="1.2" fill="#0693E3" opacity="0.4"/>
  <circle cx="84" cy="90" r="1.2" fill="#9B51E0" opacity="0.4"/>
  <circle cx="60" cy="104" r="1.5" fill="#0693E3" opacity="0.6"/>
</svg>
