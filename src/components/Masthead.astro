---
const today = new Date().toLocaleDateString('en-US', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---
<header class="masthead">
  <div class="masthead-brand">
    <img src="/images/logo-icon.png" alt="CSIORS logo" class="masthead-logo" width="42" height="42" />
    <div class="masthead-name">CSIORS</div>
  </div>
  <div class="masthead-sub">Czech Slovak Institute of Oriental Studies — Data-Driven Research Unit</div>
  <div class="masthead-date"><span class="live-dot"></span> {today} &nbsp;&middot;&nbsp; 37 countries monitored &nbsp;&middot;&nbsp; Last field data: 2h ago</div>
</header>
