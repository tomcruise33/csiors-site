---
import { t } from '../i18n/translations';
interface Props { lang?: 'en' | 'sk'; }
const { lang = 'en' } = Astro.props;

const locale = lang === 'sk' ? 'sk-SK' : 'en-US';
const today = new Date().toLocaleDateString(locale, {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---
<header class="masthead">
  <div class="masthead-brand">
    <a href="/" class="masthead-logo-link">
      <img src="/images/logo-icon.png" alt="CSIORS" class="masthead-logo" width="52" height="52" />
    </a>
    <div>
      <div class="masthead-name">CSIORS</div>
      <div class="masthead-sub">Czech-Slovak Institute of Oriental Studies</div>
    </div>
  </div>
  <div class="masthead-rule"></div>
  <div class="masthead-date"><span class="live-dot"></span> {today}</div>
</header>
