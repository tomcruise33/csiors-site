---
import { t } from '../i18n/translations';
interface Props { lang?: 'en' | 'sk'; }
const { lang = 'en' } = Astro.props;
---
<header class="masthead">
  <div class="masthead-brand">
    <a href="/" class="masthead-logo-link">
      <img src="/images/logo-mark-256.png" alt="CSIORS" class="masthead-logo" width="72" height="72" />
    </a>
    <div>
      <div class="masthead-name">CSIORS</div>
      <div class="masthead-sub">Czech-Slovak Institute of Oriental Studies</div>
    </div>
  </div>
  <div class="masthead-rule"></div>
</header>
