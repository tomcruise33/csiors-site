---
const today = new Date().toLocaleDateString('en-US', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---
<header class="masthead">
  <a href="/" class="masthead-logo-link">
    <img src="/images/logo-full.png" alt="CSIORS — Czech Slovak Institute of Oriental Studies" class="masthead-logo-full" width="420" height="189" />
  </a>
  <div class="masthead-date"><span class="live-dot"></span> {today} &nbsp;&middot;&nbsp; 37 countries monitored &nbsp;&middot;&nbsp; Last field data: 2h ago</div>
</header>
