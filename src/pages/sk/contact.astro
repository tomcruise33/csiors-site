---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/translations';
const lang = 'sk';
---
<BaseLayout lang={lang} title="Kontakt — CSIORS" description="Spojte sa s Česko-slovenským inštitútom orientálnych štúdií.">
<div class="container">

  <section class="page-hero">
    <div class="page-hero-tag">{t(lang, 'contact.tag')}</div>
    <h1 class="page-hero-title">{t(lang, 'contact.title')}</h1>
    <p class="page-hero-lede">{t(lang, 'contact.lede')}</p>
  </section>

  <section class="page-section">
    <div class="contact-layout">
      <!-- Form -->
      <div class="contact-form-wrap">
        <form class="contact-form" action="https://formspree.io/f/xvzwdbbp" method="POST">
          <input type="hidden" name="_next" value="https://csiors-site.vercel.app/sk/thank-you">
          <input type="hidden" name="_subject" value="CSIORS Kontaktný formulár">
          <input type="hidden" name="_language" value="sk">
          <div class="form-group">
            <label class="form-label" for="name">{t(lang, 'contact.name')}</label>
            <input class="form-input" type="text" id="name" name="name" required placeholder="Vaše celé meno">
          </div>
          <div class="form-group">
            <label class="form-label" for="email">{t(lang, 'contact.email')}</label>
            <input class="form-input" type="email" id="email" name="email" required placeholder="vy@organizacia.org">
          </div>
          <div class="form-group">
            <label class="form-label" for="org">{t(lang, 'contact.org')} <span class="form-optional">{t(lang, 'contact.optional')}</span></label>
            <input class="form-input" type="text" id="org" name="organization" placeholder="Vaša inštitúcia alebo organizácia">
          </div>
          <div class="form-group">
            <label class="form-label" for="subject">{t(lang, 'contact.subject')}</label>
            <select class="form-input form-select" id="subject" name="subject" required>
              <option value="" disabled selected>{t(lang, 'contact.selectTopic')}</option>
              <option value="research">{t(lang, 'contact.research')}</option>
              <option value="partnership">{t(lang, 'contact.partnership')}</option>
              <option value="expert">{t(lang, 'contact.expert')}</option>
              <option value="watchtower">{t(lang, 'contact.watchtowerAccess')}</option>
              <option value="media">{t(lang, 'contact.media')}</option>
              <option value="other">{t(lang, 'contact.other')}</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label" for="message">{t(lang, 'contact.message')}</label>
            <textarea class="form-input form-textarea" id="message" name="message" required rows="5" placeholder="Ako vám môžeme pomôcť?"></textarea>
          </div>
          <button type="submit" class="form-submit">{t(lang, 'contact.send')}</button>
          <p class="form-note">{t(lang, 'contact.responseTime')}</p>
        </form>
      </div>

      <!-- Info sidebar -->
      <div class="contact-info">
        <div class="contact-info-block">
          <div class="contact-info-label">{t(lang, 'contact.directEmail')}</div>
          <a href="mailto:tomaskrizan1@gmail.com" class="contact-info-value">tomaskrizan1@gmail.com</a>
        </div>
        <div class="contact-info-block">
          <div class="contact-info-label">{t(lang, 'contact.fieldReports')}</div>
          <a href="https://ee-eu.kobotoolbox.org/x/VYfRrAuW" target="_blank" rel="noopener" class="contact-info-value">Odoslať cez KoboToolbox &rarr;</a>
          <p class="contact-info-note">Anonymný prieskum pre respondentov v monitorovaných krajinách.</p>
        </div>
        <div class="contact-info-block">
          <div class="contact-info-label">{t(lang, 'contact.forExperts')}</div>
          <p class="contact-info-note">Budujeme sieť regionálnych špecialistov na MENA a Africký roh. Ak sa váš výskum zhoduje s našimi oblasťami záujmu — migrácia, potravinová bezpečnosť, regionálna stabilita — vyberte vo formulári „Expertný príspevok".</p>
        </div>
        <div class="contact-info-block">
          <div class="contact-info-label">{t(lang, 'contact.forOrgs')}</div>
          <p class="contact-info-note">MVO, vládne orgány a akademické inštitúcie môžu požiadať o prístup k dashboardu Watchtower alebo diskutovať o spravodajských partnerstvách na mieru.</p>
        </div>
      </div>
    </div>
  </section>

</div>
</BaseLayout>
