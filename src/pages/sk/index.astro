---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { authors, getAuthorByName } from '../../data/authors';

const lang = 'sk';

// Fetch real content (same as EN)
const allExpert = (await getCollection('expert'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allBriefs = (await getCollection('briefs'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featured = allExpert.find(e => e.data.image) || allExpert[0];

const latestArticles = allExpert
  .filter(e => e.id !== featured?.id)
  .slice(0, 6);

const latestBrief = allBriefs[0];

const authorCounts: Record<string, number> = {};
for (const article of allExpert) {
  const name = article.data.author?.replace(/"/g, '') || 'Unknown';
  authorCounts[name] = (authorCounts[name] || 0) + 1;
}

const regionCounts: Record<string, number> = {};
for (const article of allExpert) {
  const r = article.data.region;
  regionCounts[r] = (regionCounts[r] || 0) + 1;
}
const topRegions = Object.entries(regionCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 6);

const oldest = allExpert[allExpert.length - 1]?.data.date;
const newest = allExpert[0]?.data.date;
const yearRange = oldest && newest
  ? `${oldest.getFullYear()}–${newest.getFullYear()}`
  : '2022–2026';

function formatDate(date: Date) {
  return date.toLocaleDateString('sk-SK', { day: 'numeric', month: 'long', year: 'numeric' });
}

function formatDateShort(date: Date) {
  return date.toLocaleDateString('sk-SK', { month: 'short', year: 'numeric' });
}

const topAuthors = Object.entries(authorCounts)
  .filter(([name]) => name !== 'csiors')
  .sort((a, b) => b[1] - a[1])
  .slice(0, 4)
  .map(([name, count]) => ({
    name,
    count,
    profile: getAuthorByName(name),
  }));
---
<BaseLayout
  lang="sk"
  title="CSIORS — Česko-slovenský inštitút orientálnych štúdií"
  description="Dátami riadené spravodajstvo o migrácii, potravinovej bezpečnosti a regionálnej stabilite. 155+ odborných publikácií, terénna prieskumná sieť v 37 krajinách."
>

<!-- ===== HERO ===== -->
<section class="hp-hero">
  <div class="container">
    <div class="hp-hero-inner">
      <div class="hp-hero-content">
        <div class="hp-hero-tag">Nezávislý výskumný inštitút · od 2022</div>
        <h1 class="hp-hero-title">Terénne spravodajstvo pre región v pohybe</h1>
        <p class="hp-hero-lede">CSIORS prináša dátami podloženú analýzu migrácie, potravinovej bezpečnosti a politickej stability na Blízkom východe, v severnej Afrike a na Africkom rohu — založenú na anonymných terénnych dátach z našej prieskumnej siete.</p>
        <div class="hp-hero-stats">
          <div class="hp-stat">
            <span class="hp-stat-val">{allExpert.length}</span>
            <span class="hp-stat-lbl">Publikácií</span>
          </div>
          <div class="hp-stat">
            <span class="hp-stat-val">37</span>
            <span class="hp-stat-lbl">Krajín</span>
          </div>
          <div class="hp-stat">
            <span class="hp-stat-val">{Object.keys(authorCounts).filter(n => n !== 'csiors').length}</span>
            <span class="hp-stat-lbl">Analytikov</span>
          </div>
          <div class="hp-stat">
            <span class="hp-stat-val">{yearRange}</span>
            <span class="hp-stat-lbl">Aktívne</span>
          </div>
        </div>
        <div class="hp-hero-actions">
          <a href="/sk/feed" class="cta-button">Prehľadávať publikácie</a>
          <a href="/sk/about" class="cta-link">O inštitúte &rarr;</a>
        </div>
      </div>
      <div class="hp-hero-visual">
        <div class="hp-region-map">
          {topRegions.map(([region, count]) => (
            <div class="hp-region-pill">
              <span class="hp-region-name">{region}</span>
              <span class="hp-region-count">{count}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== FEATURED ===== -->
{featured && (
<section class="hp-featured">
  <div class="container">
    <div class="hp-section-label">Vybraná analýza</div>
    <div class="hp-featured-card">
      {featured.data.image && (
        <div class="hp-featured-img">
          <img src={featured.data.image} alt="" loading="lazy" />
          <div class="hp-featured-img-overlay"></div>
        </div>
      )}
      <div class="hp-featured-body">
        <div class="hp-featured-meta">
          <span class="hp-featured-region">{featured.data.region}</span>
          <span class="hp-featured-date">{formatDate(featured.data.date)}</span>
        </div>
        <h2 class="hp-featured-title">
          <a href={`/expert/${featured.id}`}>{featured.data.title}</a>
        </h2>
        {featured.data.subtitle && (
          <p class="hp-featured-sub">{featured.data.subtitle}</p>
        )}
        <div class="hp-featured-author">
          <span class="hp-featured-author-name">{featured.data.author?.replace(/"/g, '')}</span>
          {featured.data.category && (
            <span class="hp-featured-cat">{featured.data.category?.replace(/"/g, '')}</span>
          )}
        </div>
      </div>
    </div>
  </div>
</section>
)}

<!-- ===== LATEST BRIEF ===== -->
{latestBrief && (
<div class="container">
  <section class="hp-brief-section">
    <div class="hp-section-label">Najnovšia spravodajská správa</div>
    <article class="hp-brief-card">
      <div class="hp-brief-body">
        <div class="feed-type">Terénne varovanie — {latestBrief.data.region}</div>
        <h2 class="hp-brief-title">
          <a href={`/briefs/${latestBrief.id}`}>{latestBrief.data.title}</a>
        </h2>
        <p class="hp-brief-summary">{latestBrief.data.summary}</p>
        <div class="feed-data-strip">
          <span class="feed-data-item">
            <span class="feed-data-label">EWS</span>
            <span class="feed-data-val" style={`color: var(--${latestBrief.data.alert === 'alert' ? 'red-alert' : latestBrief.data.alert === 'watch' ? 'amber' : 'green'})`}>
              {latestBrief.data.ews}/100
            </span>
          </span>
          {latestBrief.data.food_price && (
            <span class="feed-data-item">
              <span class="feed-data-label">Ceny potravín</span>
              <span class="feed-data-val">{latestBrief.data.food_price}</span>
            </span>
          )}
          <span class="feed-data-item">
            <span class="feed-data-label">Odpovedí</span>
            <span class="feed-data-val">{latestBrief.data.responses}</span>
          </span>
          <span class="feed-data-item feed-data-date">{formatDate(latestBrief.data.date)}</span>
        </div>
      </div>
    </article>
  </section>
</div>
)}

<!-- ===== ARTICLES GRID ===== -->
<div class="container">
  <section class="hp-articles-section">
    <div class="hp-section-header">
      <div class="hp-section-label">Odborná analýza</div>
      <a href="/sk/feed" class="hp-section-link">Všetkých {allExpert.length} publikácií &rarr;</a>
    </div>
    <div class="hp-articles-grid">
      {latestArticles.map(item => (
        <article class="article-card">
          <a href={`/expert/${item.id}`} class="article-card-link">
            <div class="article-card-img">
              {item.data.image ? (
                <img src={item.data.image} alt="" loading="lazy" />
              ) : (
                <div class="article-card-img-placeholder">
                  <span class="article-card-region-bg">{item.data.region}</span>
                </div>
              )}
            </div>
            <div class="article-card-body">
              <div class="article-card-meta">
                <span class="article-card-region">{item.data.region}</span>
                <span class="article-card-date">{formatDateShort(item.data.date)}</span>
              </div>
              <h3 class="article-card-title">{item.data.title}</h3>
              <div class="article-card-footer">
                <span class="article-card-author">{item.data.author?.replace(/"/g, '')}</span>
              </div>
            </div>
          </a>
        </article>
      ))}
    </div>
  </section>
</div>

<!-- ===== EXPERTS ===== -->
<section class="hp-experts">
  <div class="container">
    <div class="hp-section-header">
      <div class="hp-section-label">Naši analytici</div>
      <a href="/sk/about" class="hp-section-link">Celý tím &rarr;</a>
    </div>
    <p class="hp-experts-intro">Analýzy CSIORS vytvárajú regionálni špecialisti s hlbokými terénnnymi znalosťami a akademickými kvalifikáciami. Každá publikácia je založená na primárnych dátach a expertíze priamo z terénu.</p>
    <div class="hp-experts-grid">
      {topAuthors.map(({ name, count, profile }) => (
        <div class="hp-expert-card">
          <div class="hp-expert-avatar">
            <span class="hp-expert-initials">{name.split(' ').map(n => n[0]).join('')}</span>
          </div>
          <div class="hp-expert-info">
            <div class="hp-expert-name">{profile?.name || name}</div>
            <div class="hp-expert-title">{profile?.titleSk || profile?.title || 'Výskumný pracovník'}</div>
            <p class="hp-expert-bio">{(profile?.bioSk || profile?.bio || '').slice(0, 180)}…</p>
            <div class="hp-expert-meta">
              <span class="hp-expert-articles">{count} publikácií</span>
              {profile?.regions && (
                <span class="hp-expert-regions">{profile.regions.slice(0, 3).join(' · ')}</span>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ===== METHODOLOGY ===== -->
<section class="hp-methodology">
  <div class="container">
    <div class="hp-section-label">Ako pracujeme</div>
    <div class="hp-method-grid">
      <div class="hp-method-item">
        <div class="hp-method-num">01</div>
        <div class="hp-method-title">Terénny zber</div>
        <p class="hp-method-text">Anonymné odpovede zbierané cez našu sieť KoboToolbox v 37 krajinách. Respondenti hlásia vysídlenie, ceny potravín, bezpečnosť a prístup k zdravotníctvu.</p>
      </div>
      <div class="hp-method-item">
        <div class="hp-method-num">02</div>
        <div class="hp-method-title">Skóre včasného varovania</div>
        <p class="hp-method-text">Náš kompozitný EWS agreguje zmeny cien potravín, mieru vysídlenia, vnímanie bezpečnosti a prístup k zdravotníctvu do jedného ukazovateľa 0–100 na krajinu.</p>
      </div>
      <div class="hp-method-item">
        <div class="hp-method-num">03</div>
        <div class="hp-method-title">Odborná analýza</div>
        <p class="hp-method-text">Regionálni špecialisti kontextualizujú terénne dáta politickou analýzou, historickými trendmi a open-source spravodajstvom — publikované ako výskum na úrovni politických odporúčaní.</p>
      </div>
      <div class="hp-method-item">
        <div class="hp-method-num">04</div>
        <div class="hp-method-title">Otvorený prístup</div>
        <p class="hp-method-text">Všetky publikácie sú voľne prístupné. Náš Watchtower dashboard poskytuje monitoring v reálnom čase pre inštitucionálnych predplatiteľov a humanitárnych partnerov.</p>
      </div>
    </div>
  </div>
</section>

<!-- ===== CTA ===== -->
<section class="hp-cta">
  <div class="container">
    <div class="hp-cta-inner">
      <div class="hp-cta-content">
        <h2 class="hp-cta-title">Prispejte terénnym spravodajstvom</h2>
        <p class="hp-cta-text">Nachádzate sa v jednej z našich 37 monitorovaných krajín? Vaša anonymná terénna správa posilní náš systém včasného varovania a obohatí tu publikovanú analýzu. Trvá 5 minút.</p>
        <div class="hp-hero-actions">
          <a href="https://ee-eu.kobotoolbox.org/x/VYfRrAuW" target="_blank" rel="noopener" class="cta-button">Odoslať terénnu správu</a>
          <a href="/sk/watchtower" class="cta-link">Watchtower Dashboard &rarr;</a>
        </div>
      </div>
      <div class="hp-cta-stats">
        <div class="hp-cta-stat">
          <div class="hp-cta-stat-val">{allExpert.length + allBriefs.length}</div>
          <div class="hp-cta-stat-lbl">Celkový počet publikácií</div>
        </div>
        <div class="hp-cta-stat">
          <div class="hp-cta-stat-val">37</div>
          <div class="hp-cta-stat-lbl">Pokrytých krajín</div>
        </div>
        <div class="hp-cta-stat">
          <div class="hp-cta-stat-val">50+</div>
          <div class="hp-cta-stat-lbl">Monitorovaných miest</div>
        </div>
      </div>
    </div>
  </div>
</section>

</BaseLayout>
