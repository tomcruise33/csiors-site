---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/translations';
import { getCollection } from 'astro:content';

const lang = 'sk';

const briefs = await getCollection('briefs');
const expert = await getCollection('expert');

const allBriefs = briefs.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const allExpert = expert.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allContent = [
  ...allBriefs.map(b => ({ type: 'brief' as const, entry: b })),
  ...allExpert.map(e => ({ type: 'expert' as const, entry: e })),
].sort((a, b) => b.entry.data.date.valueOf() - a.entry.data.date.valueOf());

const featured = allContent[0];
const rest = allContent.slice(1);

function formatDate(date: Date) {
  return date.toLocaleDateString('sk-SK', { day: 'numeric', month: 'long', year: 'numeric' });
}
---
<BaseLayout lang={lang} title="Spravodajský kanál — CSIORS" description="Prehľadajte spravodajské správy a expertné analýzy CSIORS o migrácii, potravinovej bezpečnosti a regionálnej stabilite.">
<div class="container">

  <section class="page-hero">
    <div class="page-hero-tag">{t(lang, 'feed.tag')}</div>
    <h1 class="page-hero-title">{t(lang, 'feed.title')}</h1>
    <p class="page-hero-lede">{t(lang, 'feed.lede')}</p>
  </section>

  <section class="feed-stream">

    {featured && (
      <article class="feed-item feed-featured">
        {featured.type === 'brief' ? (
          <div class="feed-type">{t(lang, 'home.fieldAlert')}</div>
        ) : (
          <div class="feed-type feed-type-expert">{t(lang, 'home.expertAnalysis')}</div>
        )}
        <div class="brief-meta">
          <span class="brief-region">{featured.entry.data.region}</span>
          <span class="brief-dot"></span>
          <span class="brief-date">{formatDate(featured.entry.data.date)}</span>
        </div>
        <h2 class="feed-headline"><a href={`/${featured.type === 'brief' ? 'briefs' : 'expert'}/${featured.entry.id}`}>{featured.entry.data.title}</a></h2>
        <p class="feed-summary">{featured.entry.data.summary}</p>
        {featured.type === 'brief' && (
          <div class="feed-data-strip">
            <span class="feed-data-item"><span class="feed-data-label">EWS</span> <span class="feed-data-val" style={`color: var(--${featured.entry.data.alert === 'alert' ? 'red-alert' : featured.entry.data.alert === 'watch' ? 'amber' : 'green'})`}>{featured.entry.data.ews}/100</span></span>
            {featured.entry.data.food_price && (
              <span class="feed-data-item"><span class="feed-data-label">Potr.</span> <span class="feed-data-val">{featured.entry.data.food_price}</span></span>
            )}
            <span class="feed-data-item"><span class="feed-data-label">Odpovedí</span> <span class="feed-data-val">{featured.entry.data.responses}</span></span>
          </div>
        )}
        {featured.type === 'brief' && featured.entry.data.sources && (
          <div class="feed-source">CSIORS spravodajská správa · {featured.entry.data.sources}</div>
        )}
        {featured.type === 'expert' && (
          <div class="feed-expert-meta">
            <strong>{featured.entry.data.author}</strong> · Obohatené o {featured.entry.data.responses} terénnych odpovedí
          </div>
        )}
      </article>
    )}

    {rest.map(item => (
      <article class={`feed-item ${item.type === 'expert' ? 'feed-expert-item' : ''}`}>
        {item.type === 'expert' && <div class="feed-type feed-type-expert">{t(lang, 'home.expertAnalysis')}</div>}
        <div class="brief-meta">
          <span class="brief-region">{item.entry.data.region}</span>
          <span class="brief-dot"></span>
          <span class="brief-date">{formatDate(item.entry.data.date)}</span>
        </div>
        <h2 class="feed-headline-sm"><a href={`/${item.type === 'brief' ? 'briefs' : 'expert'}/${item.entry.id}`}>{item.entry.data.title}</a></h2>
        <p class="feed-summary-sm">{item.entry.data.summary}</p>
        {item.type === 'expert' && (
          <div class="feed-expert-meta">
            <strong>{item.entry.data.author}</strong> · Obohatené o {item.entry.data.responses} terénnych odpovedí
          </div>
        )}
      </article>
    ))}

  </section>

  <div class="feed-more">
    <p class="feed-end-note">Zobrazených {allContent.length} publikovaných položiek. Nové správy prichádzajú 2–3× týždenne.</p>
  </div>

</div>
</BaseLayout>
