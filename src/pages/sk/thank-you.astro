---
import BaseLayout from '../../layouts/BaseLayout.astro';
const lang = 'sk';
---
<BaseLayout lang={lang} title="Ďakujeme — CSIORS" description="Vaša správa bola prijatá.">
<div class="container">
  <section class="page-hero" style="text-align: center; padding: 5rem 0;">
    <div class="page-hero-tag">Prijaté</div>
    <h1 class="page-hero-title">Ďakujeme</h1>
    <p class="page-hero-lede" style="margin: 0 auto;">Vaša správa bola prijatá. Zvyčajne odpovedáme do 48 hodín.</p>
    <div style="margin-top: 2rem;">
      <a href="/sk/" class="cta-button">Späť na hlavnú stránku</a>
    </div>
  </section>
</div>
</BaseLayout>
