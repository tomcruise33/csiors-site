---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/translations';
const lang = 'sk';
---
<BaseLayout lang={lang} title="Watchtower — CSIORS" description="Požiadajte o prístup k dashboardu CSIORS Watchtower — monitorovanie včasného varovania v reálnom čase naprieč 37 krajinami.">
<div class="container">

  <section class="wt-hero">
    <div class="wt-hero-badge">{t(lang, 'wt.badge')}</div>
    <h1 class="wt-hero-title">{t(lang, 'wt.title')}</h1>
    <p class="wt-hero-sub">{t(lang, 'wt.sub')}</p>
  </section>

  <!-- What you get -->
  <section class="page-section">
    <div class="wt-features">
      <div class="wt-feature">
        <div class="wt-feature-icon">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <circle cx="14" cy="14" r="12" stroke="url(#g1)" stroke-width="1.5"/>
            <circle cx="14" cy="14" r="4" fill="url(#g1)"/>
            <defs><linearGradient id="g1" x1="0" y1="0" x2="28" y2="28"><stop stop-color="#0693E3"/><stop offset="1" stop-color="#9B51E0"/></linearGradient></defs>
          </svg>
        </div>
        <h3 class="wt-feature-title">Živé EWS skóre</h3>
        <p class="wt-feature-text">Skóre včasného varovania na úrovni krajín aktualizované s každou novou terénnou odpoveďou. Sledujte trendy, nastavte prahové upozornenia a sledujte históriu skóre.</p>
      </div>
      <div class="wt-feature">
        <div class="wt-feature-icon">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <rect x="3" y="8" width="4" height="17" rx="1" fill="url(#g2)" opacity="0.4"/>
            <rect x="9" y="5" width="4" height="20" rx="1" fill="url(#g2)" opacity="0.6"/>
            <rect x="15" y="11" width="4" height="14" rx="1" fill="url(#g2)" opacity="0.8"/>
            <rect x="21" y="3" width="4" height="22" rx="1" fill="url(#g2)"/>
            <defs><linearGradient id="g2" x1="0" y1="0" x2="28" y2="28"><stop stop-color="#0693E3"/><stop offset="1" stop-color="#9B51E0"/></linearGradient></defs>
          </svg>
        </div>
        <h3 class="wt-feature-title">Sledovanie cien potravín</h3>
        <p class="wt-feature-text">Týždenné indexy cien potravín pre každú monitorovanú krajinu, zostavené z terénnych prieskumných dát a krížovo overené s trhovým monitoringom WFP.</p>
      </div>
      <div class="wt-feature">
        <div class="wt-feature-icon">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <path d="M14 3L26 25H2L14 3Z" stroke="url(#g3)" stroke-width="1.5" fill="none"/>
            <line x1="14" y1="11" x2="14" y2="18" stroke="url(#g3)" stroke-width="1.5" stroke-linecap="round"/>
            <circle cx="14" cy="21" r="1" fill="url(#g3)"/>
            <defs><linearGradient id="g3" x1="0" y1="0" x2="28" y2="28"><stop stop-color="#0693E3"/><stop offset="1" stop-color="#9B51E0"/></linearGradient></defs>
          </svg>
        </div>
        <h3 class="wt-feature-title">Prahové upozornenia</h3>
        <p class="wt-feature-text">Automatické notifikácie keď EWS skóre krajiny prekročí kritické prahy. Včasné varovanie pred zhoršením situácie.</p>
      </div>
      <div class="wt-feature">
        <div class="wt-feature-icon">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <circle cx="8" cy="14" r="3" stroke="url(#g4)" stroke-width="1.5"/>
            <circle cx="20" cy="8" r="3" stroke="url(#g4)" stroke-width="1.5"/>
            <circle cx="20" cy="20" r="3" stroke="url(#g4)" stroke-width="1.5"/>
            <line x1="11" y1="13" x2="17" y2="9" stroke="url(#g4)" stroke-width="1"/>
            <line x1="11" y1="15" x2="17" y2="19" stroke="url(#g4)" stroke-width="1"/>
            <defs><linearGradient id="g4" x1="0" y1="0" x2="28" y2="28"><stop stop-color="#0693E3"/><stop offset="1" stop-color="#9B51E0"/></linearGradient></defs>
          </svg>
        </div>
        <h3 class="wt-feature-title">Mapovanie odpovedí</h3>
        <p class="wt-feature-text">Vizualizujte hustotu anonymných terénnych odpovedí podľa krajiny a mesta. Pochopte medzery v pokrytí a spoľahlivosť dát na prvý pohľad.</p>
      </div>
    </div>
  </section>

  <!-- Access form -->
  <section class="page-section wt-access-section">
    <div class="wt-access-card">
      <div class="wt-access-header">
        <h2 class="wt-access-title">{t(lang, 'wt.requestAccess')}</h2>
        <div class="wt-access-badge">{t(lang, 'wt.freeEval')}</div>
      </div>
      <p class="wt-access-desc">Watchtower je momentálne v evaluácii. Prístup je zadarmo pre MVO, vládne agentúry, akademické inštitúcie a humanitárne organizácie. Žiadosti posudzujeme manuálne — zvyčajne do 48 hodín.</p>

      <form class="wt-access-form" action="https://formspree.io/f/xaqpaddb" method="POST">
        <input type="hidden" name="_next" value="https://csiors-site.vercel.app/sk/thank-you">
        <input type="hidden" name="_subject" value="Žiadosť o prístup k Watchtower">
        <input type="hidden" name="_language" value="sk">
        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="wt-name">{t(lang, 'wt.fullName')}</label>
            <input class="form-input" type="text" id="wt-name" name="name" required placeholder="Vaše meno">
          </div>
          <div class="form-group">
            <label class="form-label" for="wt-email">{t(lang, 'wt.workEmail')}</label>
            <input class="form-input" type="email" id="wt-email" name="email" required placeholder="vy@organizacia.org">
          </div>
        </div>
        <div class="form-group">
          <label class="form-label" for="wt-org">{t(lang, 'wt.organization')}</label>
          <input class="form-input" type="text" id="wt-org" name="organization" required placeholder="Vaša inštitúcia alebo organizácia">
        </div>
        <div class="form-group">
          <label class="form-label" for="wt-role">{t(lang, 'wt.useCase')} <span class="form-optional">(nepovinné)</span></label>
          <textarea class="form-input form-textarea" id="wt-role" name="use_case" rows="3" placeholder="Stručne opíšte ako plánujete využívať dáta Watchtower"></textarea>
        </div>
        <button type="submit" class="form-submit wt-submit">{t(lang, 'wt.requestAccess')}</button>
      </form>
    </div>
  </section>

  <!-- Current status -->
  <section class="page-section">
    <div class="wt-status-strip">
      <div class="wt-status-item">
        <span class="wt-status-dot" style="background: var(--green);"></span>
        <span class="wt-status-text">Dashboard v prevádzke</span>
      </div>
      <div class="wt-status-item">
        <span class="wt-status-text">Posledný príjem dát: <strong>pred 2h</strong></span>
      </div>
      <div class="wt-status-item">
        <span class="wt-status-text">37 krajín · 7 aktívnych EWS zón</span>
      </div>
    </div>
  </section>

</div>
</BaseLayout>
