        <g class="map-point"><circle cx="648" cy="165" r="20" class="map-ripple" fill="#f59e0b" opacity="0"/><circle cx="648" cy="165" r="12" class="map-pulse-ring" fill="#f59e0b" opacity="0.06"/><circle cx="648" cy="165" r="3.5" fill="#f59e0b" filter="url(#glow)"/><g class="map-label"><rect x="662" y="152" width="108" height="34" rx="4" fill="rgba(10,12,20,0.95)" stroke="rgba(245,158,11,0.3)" stroke-width="0.6"/><text x="670" y="166" fill="#f59e0b" font-size="10" font-family="'IBM Plex Mono',monospace" font-weight="600">Lebanon</text><text x="670" y="180" fill="rgba(255,255,255,0.5)" font-size="8" font-family="'IBM Plex Mono',monospace">EWS 44 · 8 resp</text></g></g>
        <g class="map-point"><circle cx="610" cy="465" r="20" class="map-ripple" fill="#f59e0b" opacity="0"/><circle cx="610" cy="465" r="12" class="map-pulse-ring" fill="#f59e0b" opacity="0.06"/><circle cx="610" cy="465" r="3.5" fill="#f59e0b" filter="url(#glow)"/><g class="map-label"><rect x="626" y="452" width="116" height="34" rx="4" fill="rgba(10,12,20,0.95)" stroke="rgba(245,158,11,0.3)" stroke-width="0.6"/><text x="634" y="466" fill="#f59e0b" font-size="10" font-family="'IBM Plex Mono',monospace" font-weight="600">Ethiopia</text><text x="634" y="480" fill="rgba(255,255,255,0.5)" font-size="8" font-family="'IBM Plex Mono',monospace">EWS 42 · 34 resp</text></g></g>
        <g class="map-point"><circle cx="665" cy="135" r="24" class="map-ripple" fill="#ef4444" opacity="0"/><circle cx="665" cy="135" r="14" class="map-pulse-ring" fill="#ef4444" opacity="0.08"/><circle cx="665" cy="135" r="4.5" fill="#ef4444" filter="url(#glow)"/><g class="map-label"><rect x="681" y="122" width="100" height="34" rx="4" fill="rgba(10,12,20,0.95)" stroke="rgba(239,68,68,0.3)" stroke-width="0.6"/><text x="689" y="136" fill="#ef4444" font-size="10" font-family="'IBM Plex Mono',monospace" font-weight="600">Syria</text><text x="689" y="150" fill="rgba(255,255,255,0.5)" font-size="8" font-family="'IBM Plex Mono',monospace">EWS 39 · 17 resp</text></g></g>
        <g class="map-point"><circle cx="620" cy="85" r="20" class="map-ripple" fill="#f59e0b" opacity="0"/><circle cx="620" cy="85" r="12" class="map-pulse-ring" fill="#f59e0b" opacity="0.06"/><circle cx="620" cy="85" r="3.5" fill="#f59e0b" filter="url(#glow)"/><g class="map-label"><rect x="636" y="72" width="108" height="34" rx="4" fill="rgba(10,12,20,0.95)" stroke="rgba(245,158,11,0.3)" stroke-width="0.6"/><text x="644" y="86" fill="#f59e0b" font-size="10" font-family="'IBM Plex Mono',monospace" font-weight="600">Turkey</text><text x="644" y="100" fill="rgba(255,255,255,0.5)" font-size="8" font-family="'IBM Plex Mono',monospace">EWS 35 · 12 resp</text></g></g>
        <g class="map-point"><circle cx="185" cy="200" r="20" class="map-ripple" fill="#22c55e" opacity="0"/><circle cx="185" cy="200" r="12" class="map-pulse-ring" fill="#22c55e" opacity="0.06"/><circle cx="185" cy="200" r="3.5" fill="#22c55e" filter="url(#glow)"/><g class="map-label"><rect x="201" y="187" width="116" height="34" rx="4" fill="rgba(10,12,20,0.95)" stroke="rgba(34,197,94,0.3)" stroke-width="0.6"/><text x="209" y="201" fill="#22c55e" font-size="10" font-family="'IBM Plex Mono',monospace" font-weight="600">Morocco</text><text x="209" y="215" fill="rgba(255,255,255,0.5)" font-size="8" font-family="'IBM Plex Mono',monospace">EWS 18 · 23 resp</text></g></g>
        <text x="20" y="505" fill="rgba(255,255,255,0.15)" font-size="9" font-family="'IBM Plex Mono',monospace">37 countries monitored · 7 shown with active EWS</text>
      </svg>
    </div>
  </div>
</section>

<!-- ===== METHODOLOGY ===== -->
<section class="hp-method reveal-section">
  <div class="container">
    <div class="hp-section-label"><span class="hp-label-dot"></span> How We Work</div>
    <div class="hp-method-grid">
      <div class="hp-method-step reveal-item" style="--delay: 0s">
        <div class="hp-method-num">01</div>
        <div class="hp-method-line"></div>
        <h3 class="hp-method-title">Field Collection</h3>
        <p class="hp-method-text">Anonymous survey responses collected through our KoboToolbox network across 37 countries. Respondents report on displacement, food prices, safety, and healthcare access.</p>
      </div>
