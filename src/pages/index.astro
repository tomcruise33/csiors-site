        <!-- Turkey -->
        <g class="map-point"><circle cx="620" cy="85" r="14" class="map-pulse" fill="#f59e0b" opacity="0.12"/><circle cx="620" cy="85" r="3.5" fill="#f59e0b" filter="url(#glow)"/><g class="map-tooltip"><rect x="635" y="70" width="125" height="42" rx="3" fill="rgba(10,12,20,0.92)" stroke="rgba(245,158,11,0.4)" stroke-width="0.8"/><text x="645" y="85" fill="#f59e0b" font-size="10" font-family="'IBM Plex Mono',monospace" font-weight="600">Turkey</text><text x="645" y="102" fill="rgba(255,255,255,0.6)" font-size="9" font-family="'IBM Plex Mono',monospace">EWS 35 · 12 resp</text></g></g>
