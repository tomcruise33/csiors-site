          <path d="M 500,70 L 540,70 580,65 640,70 700,75 720,90 710,110 680,115 640,110 600,115 560,110 530,100 520,90 510,85 Z" fill="rgba(255,255,255,0.06)"/>
          <path d="M 140,160 L 200,150 240,165 250,200 230,240 190,250 150,240 130,210 125,180 Z" fill="rgba(255,255,255,0.06)"/>
          <path d="M 240,165 L 300,150 370,155 400,170 410,210 390,250 350,260 300,255 260,240 250,200 Z"/>
          <path d="M 400,170 L 460,160 520,165 540,190 530,250 500,290 450,280 410,260 410,210 Z"/>
          <path d="M 540,165 L 580,155 610,170 620,220 600,280 570,300 540,280 530,250 540,190 Z"/>
          <path d="M 640,110 L 680,105 700,115 710,140 690,160 660,165 640,155 630,130 Z" fill="rgba(255,255,255,0.06)"/>
          <path d="M 700,115 L 740,110 770,130 780,170 760,200 730,210 700,190 690,160 710,140 Z"/>
          <path d="M 640,155 L 650,150 658,165 650,180 640,175 Z" fill="rgba(255,255,255,0.06)"/>
          <path d="M 660,200 L 730,210 780,250 800,320 770,380 720,400 670,370 640,320 630,270 640,230 Z"/>
          <path d="M 670,370 L 720,400 740,420 720,440 680,445 640,430 630,400 640,380 Z" fill="rgba(255,255,255,0.06)"/>
          <path d="M 540,280 L 600,280 640,320 640,380 610,420 560,430 520,400 510,350 520,310 Z" fill="rgba(255,255,255,0.06)"/>
          <path d="M 560,430 L 610,420 650,440 680,460 660,490 620,500 570,490 540,470 550,445 Z" fill="rgba(255,255,255,0.06)"/>
          <path d="M 660,440 L 700,420 740,440 750,470 730,500 700,510 680,490 660,470 Z"/>
        </g>
        <!-- Yemen -->
        <g class="map-point"><circle cx="690" cy="415" r="16" class="map-pulse" fill="#ef4444" opacity="0.15"/><circle cx="690" cy="415" r="4" fill="#ef4444" filter="url(#glow)"/><g class="map-tooltip"><rect x="705" y="400" width="120" height="42" rx="3" fill="rgba(10,12,20,0.92)" stroke="rgba(239,68,68,0.4)" stroke-width="0.8"/><text x="715" y="415" fill="#ef4444" font-size="10" font-family="'IBM Plex Mono',monospace" font-weight="600">Yemen</text><text x="715" y="432" fill="rgba(255,255,255,0.6)" font-size="9" font-family="'IBM Plex Mono',monospace">EWS 71 · 2 resp</text></g></g>
