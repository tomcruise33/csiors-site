---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { authors, getAuthorByName } from '../data/authors';

// Fetch real content
const allExpert = (await getCollection('expert'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allBriefs = (await getCollection('briefs'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Featured: top 1 article with image
const featured = allExpert.find(e => e.data.image) || allExpert[0];

// Latest 6 articles with images for the grid
const latestArticles = allExpert
  .filter(e => e.id !== featured?.id)
  .slice(0, 6);

// Latest brief
const latestBrief = allBriefs[0];

// Author article counts
const authorCounts: Record<string, number> = {};
for (const article of allExpert) {
  const name = article.data.author?.replace(/"/g, '') || 'Unknown';
  authorCounts[name] = (authorCounts[name] || 0) + 1;
}

// Region counts
const regionCounts: Record<string, number> = {};
for (const article of allExpert) {
  const r = article.data.region;
  regionCounts[r] = (regionCounts[r] || 0) + 1;
}
const topRegions = Object.entries(regionCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 6);

// Date range
const oldest = allExpert[allExpert.length - 1]?.data.date;
const newest = allExpert[0]?.data.date;
const yearRange = oldest && newest
  ? `${oldest.getFullYear()}–${newest.getFullYear()}`
  : '2022–2026';

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { day: 'numeric', month: 'long', year: 'numeric' });
}

function formatDateShort(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}

// Top authors for showcase (by article count)
const topAuthors = Object.entries(authorCounts)
  .filter((entry) => entry[0] !== 'csiors')
  .sort((a, b) => b[1] - a[1])
  .slice(0, 4)
  .map((entry) => {
    const authorName = entry[0];
    const articleCount = entry[1];
    const profile = getAuthorByName(authorName);
    const initials = authorName.split(' ').map((n) => n[0]).join('');
    return { authorName, articleCount, profile, initials };
  });

// Pre-computed values for template
const analystCount = Object.keys(authorCounts).filter((n) => n !== 'csiors').length;
const regionPills = topRegions.map((entry) => ({ region: entry[0], count: entry[1] }));
const briefEwsColor = latestBrief
  ? (latestBrief.data.alert === 'alert' ? 'var(--red-alert)' : latestBrief.data.alert === 'watch' ? 'var(--amber)' : 'var(--green)')
  : '';

// JSON-LD structured data
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ResearchOrganization',
  name: 'CSIORS — Czech Slovak Institute of Oriental Studies',
  alternateName: 'CSIORS',
  url: 'https://csiors.org',
  description: 'Data-driven intelligence on migration, food security, and regional stability across the Middle East, North Africa, and the Horn of Africa.',
  foundingDate: '2022',
  areaServed: ['Middle East', 'North Africa', 'Horn of Africa'],
  memberOf: {
    '@type': 'Organization',
    name: 'University of West Bohemia',
  },
  knowsAbout: ['Migration', 'Food Security', 'Regional Stability', 'Early Warning Systems', 'Field Intelligence'],
};
---
<BaseLayout
  lang="en"
  title="CSIORS — Czech Slovak Institute of Oriental Studies"
  description="Data-driven intelligence on migration, food security, and regional stability. 155+ expert publications, field survey network across 37 countries."
  jsonLd={structuredData}
>

<!-- ===== HERO SECTION ===== -->
<section class="hp-hero">
  <div class="container">
    <div class="hp-hero-inner">
      <div class="hp-hero-content">
        <div class="hp-hero-tag">Independent Research Institute · est. 2022</div>
        <h1 class="hp-hero-title">Field Intelligence for a Region in Flux</h1>
        <p class="hp-hero-lede">CSIORS delivers data-driven analysis on migration, food security, and political stability across the Middle East, North Africa, and the Horn of Africa — grounded in anonymous field data from our survey network.</p>
        <div class="hp-hero-stats">
          <div class="hp-stat">
            <span class="hp-stat-val">{allExpert.length}</span>
            <span class="hp-stat-lbl">Publications</span>
          </div>
          <div class="hp-stat">
            <span class="hp-stat-val">37</span>
            <span class="hp-stat-lbl">Countries</span>
          </div>
          <div class="hp-stat">
            <span class="hp-stat-val">{analystCount}</span>
            <span class="hp-stat-lbl">Analysts</span>
          </div>
          <div class="hp-stat">
            <span class="hp-stat-val">{yearRange}</span>
            <span class="hp-stat-lbl">Active</span>
          </div>
        </div>
        <div class="hp-hero-actions">
          <a href="/feed" class="cta-button">Browse Publications</a>
          <a href="/about" class="cta-link">About the Institute &rarr;</a>
        </div>
      </div>
      <div class="hp-hero-visual">
        <div class="hp-region-map">
          {regionPills.map((item) => (
            <div class="hp-region-pill">
              <span class="hp-region-name">{item.region}</span>
              <span class="hp-region-count">{item.count}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== FEATURED ARTICLE ===== -->
{featured && (
<section class="hp-featured">
  <div class="container">
    <div class="hp-section-label">Featured Analysis</div>
    <div class="hp-featured-card">
      {featured.data.image && (
        <div class="hp-featured-img">
          <img src={featured.data.image} alt="" loading="lazy" />
          <div class="hp-featured-img-overlay"></div>
        </div>
      )}
      <div class="hp-featured-body">
        <div class="hp-featured-meta">
          <span class="hp-featured-region">{featured.data.region}</span>
          <span class="hp-featured-date">{formatDate(featured.data.date)}</span>
        </div>
        <h2 class="hp-featured-title">
          <a href={`/expert/${featured.id}`}>{featured.data.title}</a>
        </h2>
        {featured.data.subtitle && (
          <p class="hp-featured-sub">{featured.data.subtitle}</p>
        )}
        <div class="hp-featured-author">
          <span class="hp-featured-author-name">{featured.data.author?.replace(/"/g, '')}</span>
          {featured.data.category && (
            <span class="hp-featured-cat">{featured.data.category?.replace(/"/g, '')}</span>
          )}
        </div>
      </div>
    </div>
  </div>
</section>
)}

<!-- ===== LATEST INTELLIGENCE BRIEF ===== -->
{latestBrief && (
<div class="container">
  <section class="hp-brief-section">
    <div class="hp-section-label">Latest Intelligence Brief</div>
    <article class="hp-brief-card">
      <div class="hp-brief-body">
        <div class="feed-type">Field Alert — {latestBrief.data.region}</div>
        <h2 class="hp-brief-title">
          <a href={`/briefs/${latestBrief.id}`}>{latestBrief.data.title}</a>
        </h2>
        <p class="hp-brief-summary">{latestBrief.data.summary}</p>
        <div class="feed-data-strip">
          <span class="feed-data-item">
            <span class="feed-data-label">EWS</span>
            <span class="feed-data-val" style={`color: ${briefEwsColor}`}>
              {latestBrief.data.ews}/100
            </span>
          </span>
          {latestBrief.data.food_price && (
            <span class="feed-data-item">
              <span class="feed-data-label">Food price</span>
              <span class="feed-data-val">{latestBrief.data.food_price}</span>
            </span>
          )}
          <span class="feed-data-item">
            <span class="feed-data-label">Responses</span>
            <span class="feed-data-val">{latestBrief.data.responses}</span>
          </span>
          <span class="feed-data-item feed-data-date">{formatDate(latestBrief.data.date)}</span>
        </div>
      </div>
    </article>
  </section>
</div>
)}

<!-- ===== LATEST EXPERT ARTICLES GRID ===== -->
<div class="container">
  <section class="hp-articles-section">
    <div class="hp-section-header">
      <div class="hp-section-label">Expert Analysis</div>
      <a href="/feed" class="hp-section-link">All {allExpert.length} publications &rarr;</a>
    </div>
    <div class="hp-articles-grid">
      {latestArticles.map(item => (
        <article class="article-card">
          <a href={`/expert/${item.id}`} class="article-card-link">
            <div class="article-card-img">
              {item.data.image ? (
                <img src={item.data.image} alt="" loading="lazy" />
              ) : (
                <div class="article-card-img-placeholder">
                  <span class="article-card-region-bg">{item.data.region}</span>
                </div>
              )}
            </div>
            <div class="article-card-body">
              <div class="article-card-meta">
                <span class="article-card-region">{item.data.region}</span>
                <span class="article-card-date">{formatDateShort(item.data.date)}</span>
              </div>
              <h3 class="article-card-title">{item.data.title}</h3>
              <div class="article-card-footer">
                <span class="article-card-author">{item.data.author?.replace(/"/g, '')}</span>
                {item.data.category && (
                  <span class="article-card-cat">{item.data.category?.replace(/"/g, '')}</span>
                )}
              </div>
            </div>
          </a>
        </article>
      ))}
    </div>
  </section>
</div>

<!-- ===== EXPERT VOICES ===== -->
<section class="hp-experts">
  <div class="container">
    <div class="hp-section-header">
      <div class="hp-section-label">Our Analysts</div>
      <a href="/about" class="hp-section-link">Full team &rarr;</a>
    </div>
    <p class="hp-experts-intro">CSIORS analysis is produced by a network of regional specialists with deep field knowledge and academic credentials. Every publication is grounded in primary data and on-the-ground expertise.</p>
    <div class="hp-experts-grid">
      {topAuthors.map((a) => (
        <div class="hp-expert-card">
          <div class="hp-expert-avatar">
            <span class="hp-expert-initials">{a.initials}</span>
          </div>
          <div class="hp-expert-info">
            <div class="hp-expert-name">{a.profile?.name || a.authorName}</div>
            <div class="hp-expert-title">{a.profile?.title || 'Research Fellow'}</div>
            <p class="hp-expert-bio">{a.profile?.bio?.slice(0, 180)}…</p>
            <div class="hp-expert-meta">
              <span class="hp-expert-articles">{a.articleCount} publications</span>
              {a.profile?.regions && (
                <span class="hp-expert-regions">{a.profile.regions.slice(0, 3).join(' · ')}</span>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ===== OPERATIONAL MAP ===== -->
