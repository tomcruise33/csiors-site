        <text x="20" y="505" fill="rgba(255,255,255,0.2)" font-size="9" font-family="'IBM Plex Mono',monospace">37 countries monitored · 7 shown with active EWS</text>
      </svg>
    </div>
  </section>
</div>

<!-- ===== METHODOLOGY STRIP ===== -->
<section class="hp-methodology">
  <div class="container">
    <div class="hp-section-label">How We Work</div>
    <div class="hp-method-grid">
      <div class="hp-method-item">
        <div class="hp-method-num">01</div>
        <div class="hp-method-title">Field Collection</div>
        <p class="hp-method-text">Anonymous survey responses collected through our KoboToolbox network across 37 countries. Respondents report on displacement, food prices, safety, and healthcare access.</p>
      </div>
      <div class="hp-method-item">
        <div class="hp-method-num">02</div>
        <div class="hp-method-title">Early Warning Score</div>
        <p class="hp-method-text">Our composite EWS aggregates food price changes, displacement rates, safety perceptions, and healthcare access into a single 0–100 indicator per country.</p>
      </div>
      <div class="hp-method-item">
        <div class="hp-method-num">03</div>
        <div class="hp-method-title">Expert Analysis</div>
        <p class="hp-method-text">Regional specialists contextualize field data with political analysis, historical trends, and open-source intelligence — published as policy-grade research.</p>
      </div>
      <div class="hp-method-item">
        <div class="hp-method-num">04</div>
        <div class="hp-method-title">Open Access</div>
        <p class="hp-method-text">All publications are freely accessible. Our Watchtower dashboard provides real-time monitoring for institutional subscribers and humanitarian partners.</p>
      </div>
    </div>
  </div>
</section>

<!-- ===== CTA ===== -->
<section class="hp-cta">
  <div class="container">
    <div class="hp-cta-inner">
      <div class="hp-cta-content">
        <h2 class="hp-cta-title">Contribute Field Intelligence</h2>
        <p class="hp-cta-text">Based in one of our 37 monitored countries? Your anonymous field report strengthens our Early Warning System and enriches the analysis published here. Takes 5 minutes.</p>
        <div class="hp-hero-actions">
          <a href="https://ee-eu.kobotoolbox.org/x/VYfRrAuW" target="_blank" rel="noopener" class="cta-button">Submit Field Report</a>
          <a href="/watchtower" class="cta-link">Watchtower Dashboard &rarr;</a>
        </div>
      </div>
      <div class="hp-cta-stats">
        <div class="hp-cta-stat">
          <div class="hp-cta-stat-val">{allExpert.length + allBriefs.length}</div>
          <div class="hp-cta-stat-lbl">Total Publications</div>
        </div>
        <div class="hp-cta-stat">
          <div class="hp-cta-stat-val">37</div>
          <div class="hp-cta-stat-lbl">Countries Covered</div>
        </div>
        <div class="hp-cta-stat">
          <div class="hp-cta-stat-val">50+</div>
          <div class="hp-cta-stat-lbl">Cities Monitored</div>
        </div>
      </div>
    </div>
  </div>
</section>

</BaseLayout>
