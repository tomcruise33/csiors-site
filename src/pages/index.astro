        <span class="map-legend-item"><span class="map-legend-dot" style="background: #f59e0b;"></span> Watch</span>
        <span class="map-legend-item"><span class="map-legend-dot" style="background: #22c55e;"></span> Stable</span>
      </div>
    </div>
    <div class="map-container">
