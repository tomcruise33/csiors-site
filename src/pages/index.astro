---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { authors, getAuthorByName } from '../data/authors';

// Fetch real content
const allExpert = (await getCollection('expert'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allBriefs = (await getCollection('briefs'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Featured: top 1 article with image
const featured = allExpert.find(e => e.data.image) || allExpert[0];

// Latest 6 articles for the grid
const latestArticles = allExpert
  .filter(e => e.id !== featured?.id)
  .slice(0, 6);

// Latest brief
const latestBrief = allBriefs[0];

// Author article counts
const authorCounts: Record<string, number> = {};
for (const article of allExpert) {
  const name = article.data.author?.replace(/"/g, '') || 'Unknown';
  authorCounts[name] = (authorCounts[name] || 0) + 1;
}

// Region counts
const regionCounts: Record<string, number> = {};
for (const article of allExpert) {
  const r = article.data.region;
  regionCounts[r] = (regionCounts[r] || 0) + 1;
}
const topRegions = Object.entries(regionCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 6);

// Date range
const oldest = allExpert[allExpert.length - 1]?.data.date;
const newest = allExpert[0]?.data.date;
const yearRange = oldest && newest
  ? `${oldest.getFullYear()}–${newest.getFullYear()}`
  : '2022–2026';

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { day: 'numeric', month: 'long', year: 'numeric' });
}

function formatDateShort(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}

// Top authors for showcase (by article count)
const topAuthors = Object.entries(authorCounts)
  .filter(entry => entry[0] !== 'csiors')
  .sort((a, b) => b[1] - a[1])
  .slice(0, 4)
  .map(entry => {
    const authorName = entry[0];
    const articleCount = entry[1];
    const profile = getAuthorByName(authorName);
    const initials = authorName.split(' ').map(n => n[0]).join('');
    return { authorName, articleCount, profile, initials };
  });

// Pre-computed values
const analystCount = Object.keys(authorCounts).filter(n => n !== 'csiors').length;
const briefEwsColor = latestBrief
  ? (latestBrief.data.alert === 'alert' ? 'var(--red-alert)' : latestBrief.data.alert === 'watch' ? 'var(--amber)' : 'var(--green)')
  : '';
const totalPubs = allExpert.length + allBriefs.length;

// ──────────────────────────────────────────────────────
// PRE-RENDER all dynamic HTML to avoid esbuild JSX errors
// ──────────────────────────────────────────────────────

const regionPillsHtml = topRegions.map((entry, i) =>
  `<div class="hp-region-pill reveal-item" style="--delay: ${i * 0.08}s">
    <div class="hp-pill-bar" style="--width: ${Math.round((entry[1] / topRegions[0][1]) * 100)}%"></div>
    <span class="hp-region-name">${entry[0]}</span>
    <span class="hp-region-count">${entry[1]}</span>
  </div>`
).join('');

const featuredHtml = featured ? `
<section class="hp-featured reveal-section">
  <div class="container">
    <div class="hp-section-label"><span class="hp-label-dot"></span> Featured Analysis</div>
    <a href="/expert/${featured.id}" class="hp-featured-card">
      ${featured.data.image ? `
        <div class="hp-featured-img">
          <img src="${featured.data.image}" alt="" loading="lazy" />
          <div class="hp-featured-img-overlay"></div>
        </div>
      ` : ''}
      <div class="hp-featured-body">
        <div class="hp-featured-meta">
          <span class="hp-featured-region">${featured.data.region}</span>
          <time class="hp-featured-date">${formatDate(featured.data.date)}</time>
        </div>
        <h2 class="hp-featured-title">${featured.data.title}</h2>
        ${featured.data.subtitle ? `<p class="hp-featured-sub">${featured.data.subtitle}</p>` : ''}
        <div class="hp-featured-author">
          <span class="hp-featured-author-name">${featured.data.author?.replace(/"/g, '') || ''}</span>
          ${featured.data.category ? `<span class="hp-featured-cat">${(featured.data.category as string)?.replace(/"/g, '')}</span>` : ''}
        </div>
      </div>
    </a>
  </div>
</section>
` : '';

const briefHtml = latestBrief ? `
<section class="hp-brief-section reveal-section">
  <div class="container">
    <div class="hp-section-label"><span class="hp-label-dot hp-label-dot--live"></span> Latest Intelligence Brief</div>
    <a href="/briefs/${latestBrief.id}" class="hp-brief-card">
      <div class="hp-brief-body">
        <div class="hp-brief-type">Field Alert — ${latestBrief.data.region}</div>
        <h2 class="hp-brief-title">${latestBrief.data.title}</h2>
        <p class="hp-brief-summary">${latestBrief.data.summary}</p>
        <div class="hp-brief-data">
          <div class="hp-brief-datum">
            <span class="hp-brief-datum-label">EWS</span>
            <span class="hp-brief-datum-val" style="color: ${briefEwsColor}">${latestBrief.data.ews}/100</span>
          </div>
          ${latestBrief.data.food_price ? `
            <div class="hp-brief-datum">
              <span class="hp-brief-datum-label">Food price</span>
              <span class="hp-brief-datum-val">${latestBrief.data.food_price}</span>
            </div>
          ` : ''}
          <div class="hp-brief-datum">
            <span class="hp-brief-datum-label">Responses</span>
            <span class="hp-brief-datum-val">${latestBrief.data.responses}</span>
          </div>
          <time class="hp-brief-datum hp-brief-date">${formatDate(latestBrief.data.date)}</time>
        </div>
      </div>
      <div class="hp-brief-arrow">&rarr;</div>
    </a>
  </div>
</section>
` : '';

const articlesGridHtml = latestArticles.map((item, i) => {
  const imgHtml = item.data.image
    ? `<img src="${item.data.image}" alt="" loading="lazy" />`
    : `<div class="hp-card-placeholder"><span>${item.data.region}</span></div>`;
  const catHtml = item.data.category
    ? `<span class="hp-card-cat">${(item.data.category as string)?.replace(/"/g, '')}</span>`
    : '';
  return `<article class="hp-card reveal-item" style="--delay: ${i * 0.1}s">
    <a href="/expert/${item.id}" class="hp-card-link">
      <div class="hp-card-img">${imgHtml}</div>
      <div class="hp-card-body">
        <div class="hp-card-meta">
          <span class="hp-card-region">${item.data.region}</span>
          <time class="hp-card-date">${formatDateShort(item.data.date)}</time>
        </div>
        <h3 class="hp-card-title">${item.data.title}</h3>
        <div class="hp-card-footer">
          <span class="hp-card-author">${item.data.author?.replace(/"/g, '') || ''}</span>
          ${catHtml}
        </div>
      </div>
    </a>
  </article>`;
}).join('');

const expertsGridHtml = topAuthors.map((a, i) => {
  const name = a.profile?.name || a.authorName;
  const title = a.profile?.title || 'Research Fellow';
  const bio = a.profile?.bio ? a.profile.bio.slice(0, 160) + '…' : '';
  const regionsHtml = a.profile?.regions
    ? `<span class="hp-analyst-regions">${a.profile.regions.slice(0, 3).join(' · ')}</span>`
    : '';
  return `<div class="hp-analyst-card reveal-item" style="--delay: ${i * 0.12}s">
    <div class="hp-analyst-header">
      <div class="hp-analyst-avatar">
        <span class="hp-analyst-initials">${a.initials}</span>
        <span class="hp-analyst-status"></span>
      </div>
      <div class="hp-analyst-id">
        <div class="hp-analyst-name">${name}</div>
        <div class="hp-analyst-role">${title}</div>
      </div>
    </div>
    <p class="hp-analyst-bio">${bio}</p>
    <div class="hp-analyst-meta">
      <span class="hp-analyst-pubs">${a.articleCount} publications</span>
      ${regionsHtml}
    </div>
  </div>`;
}).join('');

// JSON-LD structured data
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ResearchOrganization',
  name: 'CSIORS — Czech Slovak Institute of Oriental Studies',
  alternateName: 'CSIORS',
  url: 'https://csiors.org',
  description: 'Data-driven intelligence on migration, food security, and regional stability across the Middle East, North Africa, and the Horn of Africa.',
  foundingDate: '2022',
  areaServed: ['Middle East', 'North Africa', 'Horn of Africa'],
  memberOf: { '@type': 'Organization', name: 'University of West Bohemia' },
  knowsAbout: ['Migration', 'Food Security', 'Regional Stability', 'Early Warning Systems', 'Field Intelligence'],
};
---
<BaseLayout
  lang="en"
  title="CSIORS — Czech Slovak Institute of Oriental Studies"
  description="Data-driven intelligence on migration, food security, and regional stability. 155+ expert publications, field survey network across 37 countries."
  jsonLd={structuredData}
>

<!-- ===== HERO ===== -->
<section class="hero">
  <div class="hero-bg">
    <div class="hero-grid"></div>
    <div class="hero-glow hero-glow--1"></div>
    <div class="hero-glow hero-glow--2"></div>
    <div class="hero-scanline"></div>
  </div>
  <div class="container">
    <div class="hero-inner">
      <div class="hero-content">
        <div class="hero-tag">
          <span class="hero-tag-dot"></span>
          Independent Research Institute · est. 2022
        </div>
        <h1 class="hero-title">Field Intelligence<br />for a Region in Flux</h1>
        <p class="hero-lede">Data-driven analysis on migration, food security, and political stability across the Middle East, North Africa, and the Horn of Africa — grounded in anonymous field data from our survey network.</p>
        <div class="hero-stats">
          <div class="hero-stat">
            <span class="hero-stat-val" data-count={allExpert.length}>{allExpert.length}</span>
            <span class="hero-stat-lbl">Publications</span>
          </div>
          <div class="hero-stat">
            <span class="hero-stat-val" data-count="37">37</span>
            <span class="hero-stat-lbl">Countries</span>
          </div>
          <div class="hero-stat">
            <span class="hero-stat-val" data-count={analystCount}>{analystCount}</span>
            <span class="hero-stat-lbl">Analysts</span>
          </div>
          <div class="hero-stat">
            <span class="hero-stat-val">{yearRange}</span>
            <span class="hero-stat-lbl">Active</span>
          </div>
        </div>
        <div class="hero-actions">
          <a href="/feed" class="hero-btn hero-btn--primary">
            <span>Browse Publications</span>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/about" class="hero-btn hero-btn--ghost">About the Institute</a>
        </div>
      </div>
      <div class="hero-visual">
        <div class="hero-radar">
          <div class="hero-radar-ring hero-radar-ring--1"></div>
          <div class="hero-radar-ring hero-radar-ring--2"></div>
          <div class="hero-radar-ring hero-radar-ring--3"></div>
          <div class="hero-radar-sweep"></div>
          <div class="hero-radar-center"></div>
          <div class="hero-radar-dot hero-radar-dot--1"></div>
          <div class="hero-radar-dot hero-radar-dot--2"></div>
          <div class="hero-radar-dot hero-radar-dot--3"></div>
          <div class="hero-radar-dot hero-radar-dot--4"></div>
          <div class="hero-radar-dot hero-radar-dot--5"></div>
        </div>
        <div class="hero-regions" set:html={regionPillsHtml}></div>
      </div>
    </div>
  </div>
</section>

<!-- ===== FEATURED ARTICLE ===== -->
<Fragment set:html={featuredHtml} />

<!-- ===== LATEST BRIEF ===== -->
<Fragment set:html={briefHtml} />

<!-- ===== ARTICLES GRID ===== -->
<section class="hp-grid-section reveal-section">
  <div class="container">
    <div class="hp-section-header">
      <div class="hp-section-label"><span class="hp-label-dot"></span> Expert Analysis</div>
      <a href="/feed" class="hp-section-link">All {allExpert.length} publications &rarr;</a>
    </div>
    <div class="hp-grid" set:html={articlesGridHtml}></div>
  </div>
</section>

<!-- ===== ANALYSTS ===== -->
<section class="hp-analysts reveal-section">
  <div class="container">
    <div class="hp-section-header">
      <div class="hp-section-label"><span class="hp-label-dot"></span> Our Analysts</div>
      <a href="/about" class="hp-section-link">Full team &rarr;</a>
    </div>
    <p class="hp-analysts-intro">Regional specialists with deep field knowledge and academic credentials. Every publication is grounded in primary data and on-the-ground expertise.</p>
    <div class="hp-analysts-grid" set:html={expertsGridHtml}></div>
  </div>
</section>

<!-- ===== OPERATIONAL MAP ===== -->
<section class="hp-map reveal-section">
  <div class="container">
    <div class="hp-map-header">
      <div class="hp-section-label"><span class="hp-label-dot hp-label-dot--live"></span> Operational Map</div>
      <div class="hp-map-legend">
        <span class="hp-legend-item"><span class="hp-legend-dot" style="background:#ef4444"></span>Alert</span>
        <span class="hp-legend-item"><span class="hp-legend-dot" style="background:#f59e0b"></span>Watch</span>
        <span class="hp-legend-item"><span class="hp-legend-dot" style="background:#22c55e"></span>Stable</span>
      </div>
    </div>
    <div class="hp-map-container">
      <svg viewBox="0 0 900 520" xmlns="http://www.w3.org/2000/svg" class="hp-map-svg">
        <defs>
          <pattern id="mapGrid" width="40" height="40" patternUnits="userSpaceOnUse">
            <path d="M 40 0 L 0 0 0 40" fill="none" stroke="rgba(255,255,255,0.03)" stroke-width="0.5"/>
          </pattern>
          <filter id="glow"><feGaussianBlur stdDeviation="3" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
          <filter id="glow-lg"><feGaussianBlur stdDeviation="6" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
        </defs>
        <rect width="900" height="520" fill="url(#mapGrid)"/>
        <!-- Land masses -->
        <g fill="rgba(255,255,255,0.03)" stroke="rgba(255,255,255,0.06)" stroke-width="0.8">
          <path d="M 200,60 L 280,50 350,55 380,70 420,65 460,60 500,70 520,55 540,70 520,90 490,100 460,95 430,105 400,100 380,110 350,100 320,95 290,85 250,80 220,75 Z"/>
          <path d="M 500,70 L 540,70 580,65 640,70 700,75 720,90 710,110 680,115 640,110 600,115 560,110 530,100 520,90 510,85 Z" fill="rgba(255,255,255,0.05)"/>
          <path d="M 140,160 L 200,150 240,165 250,200 230,240 190,250 150,240 130,210 125,180 Z" fill="rgba(255,255,255,0.05)"/>
          <path d="M 240,165 L 300,150 370,155 400,170 410,210 390,250 350,260 300,255 260,240 250,200 Z"/>
          <path d="M 400,170 L 460,160 520,165 540,190 530,250 500,290 450,280 410,260 410,210 Z"/>
          <path d="M 540,165 L 580,155 610,170 620,220 600,280 570,300 540,280 530,250 540,190 Z"/>
          <path d="M 640,110 L 680,105 700,115 710,140 690,160 660,165 640,155 630,130 Z" fill="rgba(255,255,255,0.05)"/>
          <path d="M 700,115 L 740,110 770,130 780,170 760,200 730,210 700,190 690,160 710,140 Z"/>
          <path d="M 640,155 L 650,150 658,165 650,180 640,175 Z" fill="rgba(255,255,255,0.05)"/>
          <path d="M 660,200 L 730,210 780,250 800,320 770,380 720,400 670,370 640,320 630,270 640,230 Z"/>
          <path d="M 670,370 L 720,400 740,420 720,440 680,445 640,430 630,400 640,380 Z" fill="rgba(255,255,255,0.05)"/>
          <path d="M 540,280 L 600,280 640,320 640,380 610,420 560,430 520,400 510,350 520,310 Z" fill="rgba(255,255,255,0.05)"/>
          <path d="M 560,430 L 610,420 650,440 680,460 660,490 620,500 570,490 540,470 550,445 Z" fill="rgba(255,255,255,0.05)"/>
          <path d="M 660,440 L 700,420 740,440 750,470 730,500 700,510 680,490 660,470 Z"/>
        </g>
        <!-- Connection lines -->
        <g stroke="rgba(6,147,227,0.08)" stroke-width="0.5" fill="none" stroke-dasharray="4 4">
          <line x1="690" y1="415" x2="560" y2="360"/>
          <line x1="560" y1="360" x2="665" y2="135"/>
          <line x1="665" y1="135" x2="648" y2="165"/>
          <line x1="648" y1="165" x2="620" y2="85"/>
          <line x1="610" y1="465" x2="690" y2="415"/>
          <line x1="185" y1="200" x2="560" y2="360"/>
        </g>
        <!-- Data points with pulse -->
        <g class="map-point"><circle cx="690" cy="415" r="24" class="map-ripple" fill="#ef4444" opacity="0"/><circle cx="690" cy="415" r="14" class="map-pulse-ring" fill="#ef4444" opacity="0.08"/><circle cx="690" cy="415" r="4.5" fill="#ef4444" filter="url(#glow)"/><g class="map-label"><rect x="706" y="402" width="100" height="34" rx="4" fill="rgba(10,12,20,0.95)" stroke="rgba(239,68,68,0.3)" stroke-width="0.6"/><text x="714" y="416" fill="#ef4444" font-size="10" font-family="'IBM Plex Mono',monospace" font-weight="600">Yemen</text><text x="714" y="430" fill="rgba(255,255,255,0.5)" font-size="8" font-family="'IBM Plex Mono',monospace">EWS 71 · 2 resp</text></g></g>
