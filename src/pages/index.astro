        <g class="map-point"><circle cx="560" cy="360" r="16" class="map-pulse" fill="#ef4444" opacity="0.15"/><circle cx="560" cy="360" r="4" fill="#ef4444" filter="url(#glow)"/><g class="map-tooltip"><rect x="575" y="345" width="120" height="42" rx="3" fill="rgba(10,12,20,0.92)" stroke="rgba(239,68,68,0.4)" stroke-width="0.8"/><text x="585" y="360" fill="#ef4444" font-size="10" font-family="'IBM Plex Mono',monospace" font-weight="600">Sudan</text><text x="585" y="377" fill="rgba(255,255,255,0.6)" font-size="9" font-family="'IBM Plex Mono',monospace">EWS 67 · 4 resp</text></g></g>
