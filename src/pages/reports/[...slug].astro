---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const reports = await getCollection('reports');
  return reports.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const alertColor = entry.data.alert === 'alert' ? 'var(--red-alert)' : entry.data.alert === 'watch' ? 'var(--amber)' : 'var(--green)';
const dateStr = entry.data.date.toLocaleDateString('en-US', { day: 'numeric', month: 'long', year: 'numeric' });

// === PRE-BUILD ALL CONDITIONAL HTML (esbuild workaround) ===
const sourcesItems = (entry.data.external_sources || []);
const sourcesHtml = sourcesItems.length > 0
  ? sourcesItems.map(s => `<li>${s}</li>`).join('')
  : '';

const tagsHtml = (entry.data.tags || []).map(t =>
  `<span class="report-tag">${t}</span>`
).join('');

const bylineHtml = `<strong>CSIORS Situational Report</strong> &middot; ${dateStr}`;

const dataBoxHtml = `<div class="lead-data-box"><div class="data-box-inner">` +
  `<div class="data-box-title">${entry.data.region} — Report Indicators</div>` +
  `<div class="data-row"><span class="data-label">Early Warning Score</span><span class="data-value" style="color: ${alertColor}">${entry.data.ews} / 100</span></div>` +
  `<div class="data-row"><span class="data-label">Field entries</span><span class="data-value">${entry.data.entry_count}</span></div>` +
  `<div class="data-row"><span class="data-label">Respondents</span><span class="data-value">${entry.data.respondent_count}</span></div>` +
  `<div class="data-source">CSIORS field network &middot; ${dateStr}</div>` +
  `</div></div>`;

const sourcesBoxHtml = sourcesHtml
  ? `<div class="sidebar-block" style="margin-top: 1.5rem;"><div class="sidebar-title">External Sources</div><ul class="report-sources-list">${sourcesHtml}</ul></div>`
  : '';

// Article JSON-LD structured data
const reportUrl = 'https://csiors.org/reports/' + entry.id + '/';
const reportOgImg = 'https://csiors.org/og/' + entry.id + '.png';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: entry.data.title,
  description: entry.data.summary || '',
  image: reportOgImg,
  datePublished: entry.data.date.toISOString().split('T')[0],
  author: {
    '@type': 'Organization',
    name: 'Czech-Slovak Institute of Oriental Studies',
    url: 'https://csiors.org',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Czech-Slovak Institute of Oriental Studies',
    url: 'https://csiors.org',
    logo: {
      '@type': 'ImageObject',
      url: 'https://csiors.org/images/logo-icon.png',
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': reportUrl,
  },
  url: reportUrl,
  about: entry.data.region,
};
---
<BaseLayout title={`${entry.data.title} — CSIORS`} description={entry.data.summary} ogImage={reportOgImg} ogType="article" jsonLd={jsonLd}>
<div class="container">

  <article class="article-page">
    <div class="article-meta-top">
      <a href="/feed" class="article-back">&larr; Analysis</a>
    </div>

    <div class="article-layout">
      <div class="article-main">
        <div class="lead-tag">Situational Report — {entry.data.region}</div>
        <h1 class="article-title">{entry.data.title}</h1>
        <p class="article-byline">
          <Fragment set:html={bylineHtml} />
        </p>
        {tagsHtml && (
          <div class="report-tags">
            <Fragment set:html={tagsHtml} />
          </div>
        )}
        <div class="article-body">
          <Content />
        </div>
      </div>

      <aside class="article-sidebar">
        <Fragment set:html={dataBoxHtml} />
        <Fragment set:html={sourcesBoxHtml} />

        <div class="sidebar-block" style="margin-top: 2rem;">
          <div class="sidebar-title">Contribute</div>
          <p class="contribute-text">Based in {entry.data.region} or another monitored country? Submit an anonymous field report.</p>
          <a href="https://ee-eu.kobotoolbox.org/x/VYfRrAuW" target="_blank" rel="noopener" class="contribute-link">Submit field report &rarr;</a>
        </div>

        <div class="sidebar-block" style="margin-top: 2rem;">
          <div class="sidebar-title">Newsletter</div>
          <p class="contribute-text">Get field intelligence and expert analysis delivered to your inbox.</p>
          <a href="/newsletter" class="contribute-link">Subscribe &rarr;</a>
        </div>
      </aside>
    </div>
  </article>

</div>
</BaseLayout>
