---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout lang="en" title="Thank You — CSIORS" description="Your message has been received.">
<div class="container">
  <section class="page-hero" style="text-align: center; padding: 5rem 0;">
    <div class="page-hero-tag">Received</div>
    <h1 class="page-hero-title">Thank you</h1>
    <p class="page-hero-lede" style="margin: 0 auto;">Your message has been received. We typically respond within 48 hours.</p>
    <div style="margin-top: 2rem;">
      <a href="/" class="cta-button">Back to homepage</a>
    </div>
  </section>
</div>
</BaseLayout>
