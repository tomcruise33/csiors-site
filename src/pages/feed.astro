---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const briefs = await getCollection('briefs');
const expert = await getCollection('expert');

// Merge all content
const allContent = [
  ...briefs.map(b => ({ type: 'brief' as const, entry: b })),
  ...expert.map(e => ({ type: 'expert' as const, entry: e })),
].sort((a, b) => b.entry.data.date.valueOf() - a.entry.data.date.valueOf());

// Build region list from actual data
const regionSet = new Set<string>();
for (const item of allContent) {
  const r = item.entry.data.region;
  if (r) regionSet.add(r);
}
const regions = [...regionSet].sort();

function formatDateShort(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
function getHref(item: typeof allContent[0]) {
  return item.type === 'brief' ? `/briefs/${item.entry.id}` : `/expert/${item.entry.id}`;
}

// Pre-render filter buttons
const filtersHtml = `<button class="feed-filter active" data-filter="all">All <span class="feed-filter-count">${allContent.length}</span></button>` +
  regions.map(r => {
    const count = allContent.filter(c => c.entry.data.region === r).length;
    return `<button class="feed-filter" data-filter="${r}">${r} <span class="feed-filter-count">${count}</span></button>`;
  }).join('');

// Pre-render all article cards
const cardsHtml = allContent.map(item => {
  const e = item.entry;
  const href = getHref(item);
  const authorName = e.data.author?.replace(/"/g, '') || '';
  const region = e.data.region || '';
  const typeLabel = item.type === 'brief' ? 'Brief' : 'Analysis';
  const imgHtml = e.data.image
    ? `<img src="${e.data.image}" alt="" loading="lazy" />`
    : `<div class="article-card-img-placeholder"><span class="article-card-region-bg">${region}</span></div>`;

  return `<article class="article-card" data-region="${region}" data-type="${item.type}">
    <a href="${href}" class="article-card-link">
      <div class="article-card-img">${imgHtml}</div>
      <div class="article-card-body">
        <div class="article-card-meta">
          <span class="article-card-type">${typeLabel}</span>
          <span class="article-card-region">${region}</span>
          <span class="article-card-date">${formatDateShort(e.data.date)}</span>
        </div>
        <h3 class="article-card-title">${e.data.title}</h3>
        <div class="article-card-footer">
          <span class="article-card-author">${authorName}</span>
        </div>
      </div>
    </a>
  </article>`;
}).join('');
---
<BaseLayout lang="en" title="Analysis — CSIORS" description="Browse all CSIORS analysis: field briefs and expert research on migration, food security, and regional stability.">

<div class="container">
  <section class="page-hero">
    <div class="page-hero-tag">Analysis</div>
    <h1 class="page-hero-title">All Analysis</h1>
    <p class="page-hero-lede">{allContent.length} publications covering migration, food security, and regional stability across the Middle East, North Africa, and the Horn of Africa.</p>
  </section>
</div>

<div class="container">
  <section class="feed-section">
    <!-- Filters -->
    <div class="feed-filters" id="feedFilters" set:html={filtersHtml}></div>

    <!-- Grid -->
    <div class="articles-grid" id="articlesGrid" set:html={cardsHtml}></div>

    <!-- Pagination controls -->
    <div class="feed-pagination" id="feedPagination">
      <span class="feed-page-info" id="pageInfo"></span>
      <div class="feed-page-btns">
        <button class="feed-page-btn" id="prevBtn" disabled>&larr; Previous</button>
        <button class="feed-page-btn" id="nextBtn">Next &rarr;</button>
      </div>
    </div>
  </section>
</div>

<script>
  const PER_PAGE = 20;
  let currentPage = 1;
  let activeFilter = 'all';

  const cards = Array.from(document.querySelectorAll('#articlesGrid .article-card'));
  const filters = document.querySelectorAll('.feed-filter');
  const pageInfo = document.getElementById('pageInfo');
  const prevBtn = document.getElementById('prevBtn') as HTMLButtonElement;
  const nextBtn = document.getElementById('nextBtn') as HTMLButtonElement;

  function getFiltered() {
    if (activeFilter === 'all') return cards;
    return cards.filter(c => c.getAttribute('data-region') === activeFilter);
  }

  function render() {
    const filtered = getFiltered();
    const total = filtered.length;
    const totalPages = Math.ceil(total / PER_PAGE);
    if (currentPage > totalPages) currentPage = totalPages || 1;
    const start = (currentPage - 1) * PER_PAGE;
    const end = start + PER_PAGE;

    // Hide all, show only current page of filtered
    cards.forEach(c => (c as HTMLElement).style.display = 'none');
    filtered.forEach((c, i) => {
      (c as HTMLElement).style.display = (i >= start && i < end) ? '' : 'none';
    });

    // Update info
    if (pageInfo) {
      pageInfo.textContent = `Showing ${Math.min(start + 1, total)}–${Math.min(end, total)} of ${total}`;
    }
    if (prevBtn) prevBtn.disabled = currentPage <= 1;
    if (nextBtn) nextBtn.disabled = currentPage >= totalPages;
  }

  // Filter clicks
  filters.forEach(btn => {
    btn.addEventListener('click', () => {
      filters.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeFilter = btn.getAttribute('data-filter') || 'all';
      currentPage = 1;
      render();
      // Scroll to top of grid
      document.getElementById('feedFilters')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });

  // Pagination clicks
  prevBtn?.addEventListener('click', () => { currentPage--; render(); window.scrollTo({ top: 0, behavior: 'smooth' }); });
  nextBtn?.addEventListener('click', () => { currentPage++; render(); window.scrollTo({ top: 0, behavior: 'smooth' }); });

  // Initial render
  render();
</script>

</BaseLayout>
