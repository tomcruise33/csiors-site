---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const briefs = await getCollection('briefs');
const expert = await getCollection('expert');

// Sort by date descending
const allBriefs = briefs.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const allExpert = expert.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Combine and sort all content
const allContent = [
  ...allBriefs.map(b => ({ type: 'brief' as const, entry: b })),
  ...allExpert.map(e => ({ type: 'expert' as const, entry: e })),
].sort((a, b) => b.entry.data.date.valueOf() - a.entry.data.date.valueOf());

const featured = allContent[0];
const rest = allContent.slice(1);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { day: 'numeric', month: 'long', year: 'numeric' });
}
---
<BaseLayout title="Intelligence Feed — CSIORS" description="Browse CSIORS intelligence briefs and expert analyses on migration, food security, and regional stability.">
<div class="container">

  <section class="page-hero">
    <div class="page-hero-tag">Intelligence Feed</div>
    <h1 class="page-hero-title">Briefs & Analysis</h1>
    <p class="page-hero-lede">Field-data-driven intelligence on migration, food security, and regional stability. Briefs published 2–3 times per week; expert analysis monthly.</p>
  </section>

  <!-- Feed items -->
  <section class="feed-stream">

    {featured && (
      <article class="feed-item feed-featured">
        {featured.type === 'brief' ? (
          <div class="feed-type">Field Alert</div>
        ) : (
          <div class="feed-type feed-type-expert">Expert Analysis</div>
        )}
        <div class="brief-meta">
          <span class="brief-region">{featured.entry.data.region}</span>
          <span class="brief-dot"></span>
          <span class="brief-date">{formatDate(featured.entry.data.date)}</span>
        </div>
        <h2 class="feed-headline"><a href={`/${featured.type === 'brief' ? 'briefs' : 'expert'}/${featured.entry.slug}`}>{featured.entry.data.title}</a></h2>
        <p class="feed-summary">{featured.entry.data.summary}</p>
        {featured.type === 'brief' && (
          <div class="feed-data-strip">
            <span class="feed-data-item"><span class="feed-data-label">EWS</span> <span class="feed-data-val" style={`color: var(--${featured.entry.data.alert === 'alert' ? 'red-alert' : featured.entry.data.alert === 'watch' ? 'amber' : 'green'})`}>{featured.entry.data.ews}/100</span></span>
            {featured.entry.data.food_price && (
              <span class="feed-data-item"><span class="feed-data-label">Food</span> <span class="feed-data-val">{featured.entry.data.food_price}</span></span>
            )}
            <span class="feed-data-item"><span class="feed-data-label">Responses</span> <span class="feed-data-val">{featured.entry.data.responses}</span></span>
          </div>
        )}
        {featured.type === 'brief' && featured.entry.data.sources && (
          <div class="feed-source">CSIORS Intelligence Brief · {featured.entry.data.sources}</div>
        )}
        {featured.type === 'expert' && (
          <div class="feed-expert-meta">
            <strong>{featured.entry.data.author}</strong> · Enriched with {featured.entry.data.responses} field responses
          </div>
        )}
      </article>
    )}

    {rest.map(item => (
      <article class={`feed-item ${item.type === 'expert' ? 'feed-expert-item' : ''}`}>
        {item.type === 'expert' && <div class="feed-type feed-type-expert">Expert Analysis</div>}
        <div class="brief-meta">
          <span class="brief-region">{item.entry.data.region}</span>
          <span class="brief-dot"></span>
          <span class="brief-date">{formatDate(item.entry.data.date)}</span>
        </div>
        <h2 class="feed-headline-sm"><a href={`/${item.type === 'brief' ? 'briefs' : 'expert'}/${item.entry.slug}`}>{item.entry.data.title}</a></h2>
        <p class="feed-summary-sm">{item.entry.data.summary}</p>
        {item.type === 'expert' && (
          <div class="feed-expert-meta">
            <strong>{item.entry.data.author}</strong> · Enriched with {item.entry.data.responses} field responses
          </div>
        )}
      </article>
    ))}

  </section>

  <div class="feed-more">
    <p class="feed-end-note">Showing {allContent.length} published items. New briefs arrive 2–3 times per week.</p>
  </div>

</div>
</BaseLayout>
