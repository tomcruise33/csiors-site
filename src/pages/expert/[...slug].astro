---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { getAuthorByName } from '../../data/authors';

export async function getStaticPaths() {
  const expert = await getCollection('expert');
  return expert.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const dateStr = entry.data.date.toLocaleDateString('en-US', { day: 'numeric', month: 'long', year: 'numeric' });

// Build author link(s) HTML
const rawAuthor = entry.data.author || 'CSIORS';
const authorNames = rawAuthor.split(/[,&]/).map((n: string) => n.trim().replace(/[""]/g, ''));
const authorLinksHtml = authorNames.map((name: string) => {
  const found = getAuthorByName(name);
  if (found) {
    return `<a href="/author/${found.id}" class="author-byline-link">${found.name}</a>`;
  }
  return name;
}).join(' &amp; ');

// Sidebar author info
const primaryAuthor = getAuthorByName(authorNames[0]);
const sidebarAuthorHtml = primaryAuthor
  ? `<a href="/author/${primaryAuthor.id}" class="author-byline-link">${primaryAuthor.name}</a>` +
    `<p class="contribute-text" style="margin-top:0.5rem">${primaryAuthor.title}. Specializes in ${primaryAuthor.specialization.slice(0, 3).join(', ')}.</p>` +
    `<a href="/author/${primaryAuthor.id}" style="font-family:'IBM Plex Mono',monospace;font-size:0.75rem;color:var(--gradient-blue);text-decoration:none;display:inline-block;margin-top:0.4rem">View full profile &rarr;</a>`
  : `<strong>${rawAuthor}</strong><p class="contribute-text" style="margin-top:0.5rem">Contributing expert for CSIORS. Regional specialist in ${entry.data.region}.</p>`;

// === PRE-BUILD ALL CONDITIONAL HTML (esbuild workaround) ===
const heroImgHtml = entry.data.image
  ? `<div class="article-hero-img"><img src="${entry.data.image}" alt="${entry.data.title.replace(/"/g, '&quot;')}" /><div class="article-hero-overlay"></div></div>`
  : '';

const categoryLabel = entry.data.category || 'Expert Analysis';

const subtitleHtml = entry.data.subtitle
  ? `<p class="article-subtitle">${entry.data.subtitle}</p>`
  : '';

const tagSpans = (entry.data.tags || []).map((tag: string) => '<span class="article-tag">#' + tag + '</span>').join('');
const tagsHtml = tagSpans ? '<div class="article-tags">' + tagSpans + '</div>' : '';

const fieldDataHtml = (entry.data.responses && entry.data.responses > 0)
  ? `<div class="sidebar-block"><div class="sidebar-title">Field Data</div><p class="contribute-text">This analysis was enriched with <strong>${entry.data.responses}</strong> anonymous field responses from the CSIORS survey network.</p></div>`
  : '';

const ogImg = entry.data.image || `https://csiors.org/og/${entry.id}.png`;
---
<BaseLayout lang="en" title={`${entry.data.title} — CSIORS`} description={entry.data.summary} ogImage={ogImg} ogType="article">

<Fragment set:html={heroImgHtml} />

<div class="container">
  <article class="article-page">
    <div class="article-meta-top">
      <a href="/feed" class="article-back">&larr; Analysis</a>
    </div>

    <div class="article-layout">
      <div class="article-main">
        <div class="feed-type feed-type-expert" style="margin-bottom: 0.75rem;">
          <Fragment set:html={categoryLabel} />
        </div>
        <h1 class="article-title">{entry.data.title}</h1>
        <Fragment set:html={subtitleHtml} />
        <p class="article-byline">
          <Fragment set:html={authorLinksHtml} /> &middot; {dateStr} &middot; {entry.data.region}
        </p>
        <Fragment set:html={tagsHtml} />
        <div class="article-body">
          <Content />
        </div>
      </div>

      <aside class="article-sidebar">
        <div class="sidebar-block">
          <div class="sidebar-title">About the Author</div>
          <div class="expert-by"><Fragment set:html={sidebarAuthorHtml} /></div>
        </div>

        <div class="sidebar-block">
          <div class="sidebar-title">Region</div>
          <p class="contribute-text">{entry.data.region}</p>
        </div>

        <Fragment set:html={fieldDataHtml} />

        <div class="sidebar-block">
          <div class="sidebar-title">Contribute</div>
          <p class="contribute-text">
            Based in {entry.data.region}? Your field report strengthens this type of analysis.
          </p>
          <a href="https://ee-eu.kobotoolbox.org/x/VYfRrAuW" target="_blank" rel="noopener" class="contribute-link">
            Submit field report &rarr;
          </a>
        </div>
      </aside>
    </div>
  </article>
</div>

</BaseLayout>
