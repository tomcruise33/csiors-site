---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const expert = await getCollection('expert');
  return expert.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const dateStr = entry.data.date.toLocaleDateString('en-US', { day: 'numeric', month: 'long', year: 'numeric' });
---
<BaseLayout lang="en" title={`${entry.data.title} — CSIORS`} description={entry.data.summary}>

<!-- Hero image -->
{entry.data.image && (
  <div class="article-hero-img">
    <img src={entry.data.image} alt={entry.data.title} />
    <div class="article-hero-overlay"></div>
  </div>
)}

<div class="container">
  <article class="article-page">
    <div class="article-meta-top">
      <a href="/feed" class="article-back">&larr; Intelligence Feed</a>
    </div>

    <div class="article-layout">
      <div class="article-main">
        <div class="feed-type feed-type-expert" style="margin-bottom: 0.75rem;">
          {entry.data.category || 'Expert Analysis'}
        </div>
        <h1 class="article-title">{entry.data.title}</h1>
        {entry.data.subtitle && (
          <p class="article-subtitle">{entry.data.subtitle}</p>
        )}
        <p class="article-byline">
          <strong>{entry.data.author}</strong> &middot; {dateStr} &middot; {entry.data.region}
        </p>

        {entry.data.tags && entry.data.tags.length > 0 && (
          <div class="article-tags">
            {entry.data.tags.map(tag => (
              <span class="article-tag">#{tag}</span>
            ))}
          </div>
        )}

        <div class="article-body">
          <Content />
        </div>
      </div>

      <aside class="article-sidebar">
        <!-- Author -->
        <div class="sidebar-block">
          <div class="sidebar-title">About the Author</div>
          <div class="expert-by"><strong>{entry.data.author}</strong></div>
          <p class="contribute-text" style="margin-top: 0.5rem;">
            Contributing expert for CSIORS. Regional specialist in {entry.data.region}.
          </p>
        </div>

        <!-- Region -->
        <div class="sidebar-block">
          <div class="sidebar-title">Region</div>
          <p class="contribute-text">{entry.data.region}</p>
        </div>

        {entry.data.responses > 0 && (
          <div class="sidebar-block">
            <div class="sidebar-title">Field Data</div>
            <p class="contribute-text">
              This analysis was enriched with <strong>{entry.data.responses}</strong> anonymous field responses from the CSIORS survey network.
            </p>
          </div>
        )}

        <div class="sidebar-block">
          <div class="sidebar-title">Contribute</div>
          <p class="contribute-text">
            Based in {entry.data.region}? Your field report strengthens this type of analysis.
          </p>
          <a href="https://ee-eu.kobotoolbox.org/x/VYfRrAuW" target="_blank" rel="noopener" class="contribute-link">
            Submit field report &rarr;
          </a>
        </div>
      </aside>
    </div>
  </article>
</div>

</BaseLayout>
