---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const briefs = await getCollection('briefs');
  return briefs.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const alertColor = entry.data.alert === 'alert' ? 'var(--red-alert)' : entry.data.alert === 'watch' ? 'var(--amber)' : 'var(--green)';
const dateStr = entry.data.date.toLocaleDateString('en-US', { day: 'numeric', month: 'long', year: 'numeric' });

// === PRE-BUILD ALL CONDITIONAL HTML (esbuild workaround) ===
const sourcesHtml = entry.data.sources
  ? ` &middot; ${entry.data.sources}`
  : '';

const foodPriceHtml = entry.data.food_price
  ? `<div class="data-row"><span class="data-label">Food price change</span><span class="data-value up">${entry.data.food_price}</span></div>`
  : '';

const bylineHtml = `<strong>CSIORS Intelligence Brief</strong> &middot; ${dateStr}${sourcesHtml}`;

const dataBoxHtml = `<div class="lead-data-box"><div class="data-box-inner">` +
  `<div class="data-box-title">${entry.data.region} — Key Indicators</div>` +
  `<div class="data-row"><span class="data-label">Early Warning Score</span><span class="data-value" style="color: ${alertColor}">${entry.data.ews} / 100</span></div>` +
  foodPriceHtml +
  `<div class="data-row"><span class="data-label">Field responses</span><span class="data-value">${entry.data.responses}</span></div>` +
  `<div class="data-source">CSIORS field survey &middot; ${dateStr}</div>` +
  `</div></div>`;

// Article JSON-LD structured data for intelligence briefs
const briefUrl = 'https://csiors.org/briefs/' + entry.id + '/';
const briefOgImg = 'https://csiors.org/og/' + entry.id + '.png';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: entry.data.title,
  description: entry.data.summary || '',
  image: briefOgImg,
  datePublished: entry.data.date.toISOString().split('T')[0],
  author: {
    '@type': 'Organization',
    name: 'Czech-Slovak Institute of Oriental Studies',
    url: 'https://csiors.org',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Czech-Slovak Institute of Oriental Studies',
    url: 'https://csiors.org',
    logo: {
      '@type': 'ImageObject',
      url: 'https://csiors.org/images/logo-icon.png',
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': briefUrl,
  },
  url: briefUrl,
  about: entry.data.region,
};
---
<BaseLayout title={`${entry.data.title} — CSIORS`} description={entry.data.summary} ogImage={briefOgImg} ogType="article" jsonLd={jsonLd}>
<div class="container">

  <article class="article-page">
    <div class="article-meta-top">
      <a href="/feed" class="article-back">&larr; Analysis</a>
    </div>

    <div class="article-layout">
      <div class="article-main">
        <div class="lead-tag">Field Alert — {entry.data.region}</div>
        <h1 class="article-title">{entry.data.title}</h1>
        <p class="article-byline">
          <Fragment set:html={bylineHtml} />
        </p>
        <div class="article-body">
          <Content />
        </div>
      </div>

      <aside class="article-sidebar">
        <Fragment set:html={dataBoxHtml} />

        <div class="sidebar-block" style="margin-top: 2rem;">
          <div class="sidebar-title">Contribute</div>
          <p class="contribute-text">Based in {entry.data.region} or another monitored country? Submit an anonymous field report.</p>
          <a href="https://ee-eu.kobotoolbox.org/x/VYfRrAuW" target="_blank" rel="noopener" class="contribute-link">Submit field report &rarr;</a>
        </div>
      </aside>
    </div>
  </article>

</div>
</BaseLayout>
