---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout lang="en" title="Watchtower — CSIORS" description="CSIORS Watchtower field intelligence pipeline — accumulating anonymous field data from conflict zones for signal-driven situational reports.">
<div class="container">

  <section class="wt-hero">
    <div class="wt-hero-badge">Field Intelligence</div>
    <h1 class="wt-hero-title">Watchtower</h1>
    <p class="wt-hero-sub">Anonymous field data collection across MENA and the Horn of Africa. Data accumulates until signal thresholds trigger publication of Situational Reports — reviewed by humans, never auto-published.</p>
  </section>

  <!-- Accumulation status -->
  <section class="page-section">
    <h2 class="section-title">Pipeline Status</h2>
    <div class="wt-features">
      <div class="wt-feature">
        <div class="wt-feature-icon">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <rect x="3" y="8" width="4" height="17" rx="1" fill="url(#g2)" opacity="0.4"/>
            <rect x="9" y="5" width="4" height="20" rx="1" fill="url(#g2)" opacity="0.6"/>
            <rect x="15" y="11" width="4" height="14" rx="1" fill="url(#g2)" opacity="0.8"/>
            <rect x="21" y="3" width="4" height="22" rx="1" fill="url(#g2)"/>
            <defs><linearGradient id="g2" x1="0" y1="0" x2="28" y2="28"><stop stop-color="#0693E3"/><stop offset="1" stop-color="#9B51E0"/></linearGradient></defs>
          </svg>
        </div>
        <h3 class="wt-feature-title">Data Accumulation</h3>
        <p class="wt-feature-text">Field entries are collected via KoboToolbox from anonymous respondents. Data syncs daily and accumulates until publication conditions are met. Current focus: Syria, with coverage planned for Iraq, Lebanon, Turkey, Ethiopia, Sudan.</p>
      </div>
      <div class="wt-feature">
        <div class="wt-feature-icon">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <circle cx="14" cy="14" r="12" stroke="url(#g1)" stroke-width="1.5"/>
            <circle cx="14" cy="14" r="4" fill="url(#g1)"/>
            <defs><linearGradient id="g1" x1="0" y1="0" x2="28" y2="28"><stop stop-color="#0693E3"/><stop offset="1" stop-color="#9B51E0"/></linearGradient></defs>
          </svg>
        </div>
        <h3 class="wt-feature-title">Respondent Trust Scoring</h3>
        <p class="wt-feature-text">Each respondent is tracked with a trust score based on consistency, submission frequency, data completeness, and alignment with external benchmarks (WFP). Tiers: unverified, provisional, established.</p>
      </div>
      <div class="wt-feature">
        <div class="wt-feature-icon">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <path d="M14 3L26 25H2L14 3Z" stroke="url(#g3)" stroke-width="1.5" fill="none"/>
            <line x1="14" y1="11" x2="14" y2="18" stroke="url(#g3)" stroke-width="1.5" stroke-linecap="round"/>
            <circle cx="14" cy="21" r="1" fill="url(#g3)"/>
            <defs><linearGradient id="g3" x1="0" y1="0" x2="28" y2="28"><stop stop-color="#0693E3"/><stop offset="1" stop-color="#9B51E0"/></linearGradient></defs>
          </svg>
        </div>
        <h3 class="wt-feature-title">Signal Detection</h3>
        <p class="wt-feature-text">Automated checks after each sync: EWS score spikes, price changes exceeding 20%, accumulation thresholds, and quarterly reviews. Signals trigger Situational Report generation — never published without human review.</p>
      </div>
      <div class="wt-feature">
        <div class="wt-feature-icon">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <circle cx="8" cy="14" r="3" stroke="url(#g4)" stroke-width="1.5"/>
            <circle cx="20" cy="8" r="3" stroke="url(#g4)" stroke-width="1.5"/>
            <circle cx="20" cy="20" r="3" stroke="url(#g4)" stroke-width="1.5"/>
            <line x1="11" y1="13" x2="17" y2="9" stroke="url(#g4)" stroke-width="1"/>
            <line x1="11" y1="15" x2="17" y2="19" stroke="url(#g4)" stroke-width="1"/>
            <defs><linearGradient id="g4" x1="0" y1="0" x2="28" y2="28"><stop stop-color="#0693E3"/><stop offset="1" stop-color="#9B51E0"/></linearGradient></defs>
          </svg>
        </div>
        <h3 class="wt-feature-title">WFP Cross-Validation</h3>
        <p class="wt-feature-text">Field-reported commodity prices are cross-referenced against WFP Humanitarian Data Exchange benchmarks. No claim is published without external validation or explicit disclosure of limitations.</p>
      </div>
    </div>
  </section>

  <!-- Methodology link -->
  <section class="page-section">
    <p class="wt-feature-text" style="text-align: center; max-width: 40rem; margin: 0 auto;">
      Our data collection, validation, and publication process is fully documented.
      <a href="/methodology" style="color: var(--gradient-blue);">Read the Data Methodology</a> for details on trust scoring, signal thresholds, and publication criteria.
    </p>
  </section>

  <!-- Access form -->
  <section class="page-section wt-access-section">
    <div class="wt-access-card">
      <div class="wt-access-header">
        <h2 class="wt-access-title">Request Access</h2>
        <div class="wt-access-badge">Free during evaluation period</div>
      </div>
      <p class="wt-access-desc">Watchtower data access is available to NGOs, government agencies, academic institutions, and humanitarian organizations. We review requests manually — typically within 48 hours.</p>

      <form class="wt-access-form" action="https://formspree.io/f/xaqpaddb" method="POST">
        <input type="hidden" name="_next" value="https://csiors-site.vercel.app/thank-you">
        <input type="hidden" name="_subject" value="Watchtower Access Request">
        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="wt-name">Full Name</label>
            <input class="form-input" type="text" id="wt-name" name="name" required placeholder="Your name">
          </div>
          <div class="form-group">
            <label class="form-label" for="wt-email">Work Email</label>
            <input class="form-input" type="email" id="wt-email" name="email" required placeholder="you@organization.org">
          </div>
        </div>
        <div class="form-group">
          <label class="form-label" for="wt-org">Organization</label>
          <input class="form-input" type="text" id="wt-org" name="organization" required placeholder="Your institution or organization">
        </div>
        <div class="form-group">
          <label class="form-label" for="wt-role">Role / Use Case <span class="form-optional">(optional)</span></label>
          <textarea class="form-input form-textarea" id="wt-role" name="use_case" rows="3" placeholder="Briefly describe how you intend to use Watchtower data"></textarea>
        </div>
        <button type="submit" class="form-submit wt-submit">Request Access</button>
      </form>
    </div>
  </section>

  <!-- Status -->
  <section class="page-section">
    <div class="wt-status-strip">
      <div class="wt-status-item">
        <span class="wt-status-dot" style="background: var(--green);"></span>
        <span class="wt-status-text">Pipeline operational</span>
      </div>
      <div class="wt-status-item">
        <span class="wt-status-text">Sync: daily at 06:00 UTC</span>
      </div>
      <div class="wt-status-item">
        <span class="wt-status-text">1 Situational Report published</span>
      </div>
    </div>
  </section>

</div>
</BaseLayout>
